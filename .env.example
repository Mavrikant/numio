# Numio environment variables (build-time).
# Copy to `.env` and adjust. All values are optional; unset = feature disabled.
# Only PUBLIC_*-prefixed vars are exposed to client-side code (Astro convention).

# ─── Plausible Analytics ──────────────────────────────────────────────────────
# Privacy-friendly, open-source, cookieless web analytics. No consent banner is
# required because it sets no cookies and collects no personal data; an explicit
# analytics opt-out in the consent banner is still honoured.

# Set to "true" to inject the Plausible script at build time.
PUBLIC_PLAUSIBLE_ENABLED=false

# The site name as registered in your Plausible dashboard.
# Defaults to the SITE_URL host (karaman.dev) when unset.
# PUBLIC_PLAUSIBLE_DOMAIN=karaman.dev

# Script source URL. Override for a self-hosted Plausible instance, or to use a
# script extension build (outbound-links, file-downloads, tagged-events, hash, …).
# e.g. https://plausible.io/js/script.outbound-links.js
# PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# ─── Google AdSense ───────────────────────────────────────────────────────────
# Cookie-based ads. Loads only after explicit ads consent (see ConsentBanner).
PUBLIC_ADS_ENABLED=false
