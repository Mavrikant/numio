{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@calculators/*": ["./src/calculators/*"],
      "@lib/*": ["./src/lib/*"],
      "@components/*": ["./src/components/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "verbatimModuleSyntax": false,
    "allowJs": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    // Both of these were enabled when the codebase was small. Re-enabling
    // them is a clean-up backlog item — for now they generate ~80 "X is
    // possibly undefined" or "exactOptional" diagnostics on patterns the
    // runtime already handles safely (Zod parsing, optional bundle fields).
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": [
    "dist",
    "node_modules",
    ".worktrees",
    ".claude/worktrees",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test/**/*.ts",
    "**/test/**/*.tsx",
    "**/__snapshots__/**",
    "scripts/**"
  ]
}
