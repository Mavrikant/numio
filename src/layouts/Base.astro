---
import "@/styles/global.css";
import {
  DEFAULT_LOCALE,
  LOCALE_HTML_LANG,
  isRTL,
  type Locale,
} from "@/config/site";
import { t } from "@/lib/i18n";

export interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  locale = DEFAULT_LOCALE,
  title,
  description,
  canonical,
} = Astro.props;

const htmlLang = LOCALE_HTML_LANG[locale];
const dir = isRTL(locale) ? "rtl" : "ltr";
const siteName = t(locale, "site.name");
const fullTitle = title ? `${title} — ${siteName}` : siteName;
const desc = description ?? t(locale, "site.description");
---

<!doctype html>
<html lang={htmlLang} dir={dir} class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    {canonical && <link rel="canonical" href={canonical} />}
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-full bg-white text-slate-900 dark:bg-slate-900 dark:text-slate-100">
    <slot />
  </body>
</html>
