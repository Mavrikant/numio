---
import Base from "@/layouts/Base.astro";
import { DEFAULT_LOCALE } from "@/config/site";
import { t } from "@/lib/i18n";
---

<Base locale={DEFAULT_LOCALE} title="404">
  <main class="container-page py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">404</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-4 text-slate-600 dark:text-slate-400">
      The calculator or page you're looking for doesn't exist.
    </p>
    <a href={import.meta.env.BASE_URL} class="btn-primary mt-8 inline-flex">
      {t(DEFAULT_LOCALE, "nav.home")}
    </a>
  </main>
</Base>
