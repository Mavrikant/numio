---
/**
 * Category listing page — /numio/{lang}/{category}/
 *
 * Generates one page per (locale × category) combination for all categories
 * that have at least one calculator registered.
 */
import Base from "@/layouts/Base.astro";
import {
  LOCALES,
  isLocale,
  type Locale,
  SITE_NAME,
} from "@/config/site";
import {
  t,
  buildAbsoluteUrl,
  getLocalizedSlug,
  getCategoryLabel,
} from "@/lib/i18n";
import {
  getAvailableCategories,
  getCalculatorsByCategory,
} from "@/lib/registry";
import type { CalculatorCategory } from "@/types/calculator";
import Sidebar from "@/components/chrome/Sidebar.astro";

export async function getStaticPaths() {
  const categories = getAvailableCategories();
  const paths: Array<{ params: { lang: string; category: string } }> = [];

  for (const lang of LOCALES) {
    for (const category of categories) {
      paths.push({ params: { lang, category } });
    }
  }

  return paths;
}

const { lang, category } = Astro.params;

if (!lang || !isLocale(lang)) {
  return Astro.redirect("/numio/en/");
}

const locale = lang as Locale;
const cat = category as CalculatorCategory;
const calculators = getCalculatorsByCategory(cat);

if (calculators.length === 0) {
  return Astro.redirect("/404");
}

const categoryLabel = getCategoryLabel(locale, cat);
const canonical = buildAbsoluteUrl(locale, cat);
const pageDescription = t(locale, "site.description");
---

<Base locale={locale} title={categoryLabel} description={pageDescription} canonical={canonical}>
  <!-- Hreflang links (intentionally omitted — Base layout handles canonical) -->

  <main class="container-page py-8 lg:flex lg:gap-8">
    <Sidebar locale={locale} activeCategory={cat} />

    <div class="mt-6 flex-1 min-w-0 lg:mt-0">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500 dark:text-slate-400">
        <ol class="flex items-center gap-2">
          <li>
            <a
              href={`${import.meta.env.BASE_URL}${locale}/`}
              class="hover:text-slate-800 dark:hover:text-slate-200"
            >
              {t(locale, "nav.home")}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <span class="font-medium text-slate-900 dark:text-slate-100" aria-current="page">
              {categoryLabel}
            </span>
          </li>
        </ol>
      </nav>

      <header class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-4xl">
          {categoryLabel}
        </h1>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
          {calculators.length}
          {calculators.length === 1 ? "calculator" : "calculators"}
        </p>
      </header>

      <!-- Calculator grid -->
      <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {calculators.map((calc) => {
          const bundle = calc.i18n[locale] ?? calc.i18n["en"];
          const localizedSlug = getLocalizedSlug(calc.slug, locale);
          const href = `${import.meta.env.BASE_URL}${locale}/${cat}/${localizedSlug}/`;

          return (
            <a
              href={href}
              class="group flex flex-col gap-2 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:border-blue-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-600"
            >
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-base font-semibold text-slate-900 group-hover:text-blue-700 dark:text-slate-100 dark:group-hover:text-blue-400">
                  {bundle.title}
                </h2>
                {calc.priority === "P0" && (
                  <span class="shrink-0 rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900 dark:text-blue-300">
                    Popular
                  </span>
                )}
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
                {bundle.short}
              </p>
            </a>
          );
        })}
      </section>
    </div>
  </main>

  <!-- JSON-LD breadcrumb -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: SITE_NAME,
          item: buildAbsoluteUrl(locale),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: categoryLabel,
          item: canonical,
        },
      ],
    })}
  />
</Base>
