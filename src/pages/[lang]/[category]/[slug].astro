---
/**
 * Calculator detail page — /numio/{lang}/{category}/{slug}/
 *
 * Slug is locale-localized (e.g. Turkish: "vucut-kitle-indeksi" → canonical "bmi").
 * We use getCanonicalSlugFromLocalized() to resolve back to the canonical slug,
 * then look up the calculator definition.
 *
 * MDX content is loaded via import.meta.glob in a locale-aware pattern.
 */
import Base from "@/layouts/Base.astro";
import {
  LOCALES,
  isLocale,
  type Locale,
  SITE_URL,
} from "@/config/site";
import {
  t,
  buildAbsoluteUrl,
  getLocalizedSlug,
  getCanonicalSlugFromLocalized,
  getCategoryLabel,
} from "@/lib/i18n";
import {
  getAllCalculators,
  getRelatedCalculators,
} from "@/lib/registry";
import {
  buildCalculatorSeoMeta,
  buildCalculatorJsonLd,
  buildHreflang,
  buildHowToJsonLd,
  buildFaqJsonLd,
} from "@/lib/seo";
import type { CalculatorCategory } from "@/types/calculator";
import { CalculatorIsland } from "@/components/calculator/CalculatorView";
import QuickAnswer from "@/components/calculator/QuickAnswer.astro";
import AuthorityFooter from "@/components/calculator/AuthorityFooter.astro";
// Universal per-calc viz loader (auto-discovers visualizations.tsx files via
// non-eager import.meta.glob). The earlier per-slug conditional mount was
// replaced by this single slot — each calc that wants a chart just creates
// `src/calculators/{category}/{slug}/visualizations.tsx`.
import CalcVizSlot from "@/components/calculator/CalcVizSlot";

// ─── Static path generation ────────────────────────────────────────────────────

export async function getStaticPaths() {
  const allCalcs = getAllCalculators();
  const paths: Array<{
    params: { lang: string; category: string; slug: string };
    props: { canonicalSlug: string };
  }> = [];

  for (const lang of LOCALES) {
    for (const calc of allCalcs) {
      const localizedSlug = getLocalizedSlug(calc.slug, lang);
      paths.push({
        params: {
          lang,
          category: calc.category,
          slug: localizedSlug,
        },
        props: { canonicalSlug: calc.slug },
      });
    }
  }

  return paths;
}

// ─── Page setup ───────────────────────────────────────────────────────────────

const { lang, category, slug } = Astro.params;
const { canonicalSlug } = Astro.props;

// Validate locale
if (!lang || !isLocale(lang)) {
  return Astro.redirect("/numio/en/");
}
const locale = lang as Locale;
const cat = category as CalculatorCategory;

// Resolve canonical slug — the URL slug may be localized
const resolvedSlug =
  canonicalSlug ??
  getCanonicalSlugFromLocalized(slug ?? "", locale) ??
  slug;

// Load all calculators and find this one
const allCalcs = getAllCalculators();
const calc = allCalcs.find((c) => c.slug === resolvedSlug);

if (!calc) {
  return Astro.redirect("/404");
}

// Validate category matches (guard against wrong URL construction)
if (calc.category !== cat) {
  return Astro.redirect("/404");
}

// ─── SEO meta ─────────────────────────────────────────────────────────────────

const seo = buildCalculatorSeoMeta(calc, locale);
const jsonLd = buildCalculatorJsonLd(calc, locale);
const howToJsonLd = buildHowToJsonLd(calc, locale);
const faqJsonLd = buildFaqJsonLd(calc, locale);
const hreflangs = buildHreflang(cat, calc.slug);
const bundle = calc.i18n[locale] ?? calc.i18n["en"];
const categoryLabel = getCategoryLabel(locale, cat);
const relatedCalcs = getRelatedCalculators(calc.slug, 4);

// ─── MDX content ──────────────────────────────────────────────────────────────

// Load all calculator content MDX files
const allMdxModules = import.meta.glob<{ default: unknown; Content: unknown }>(
  "/src/calculators/*/*/content/*.mdx",
  { eager: true },
);

// Build a lookup key matching the pattern for this calculator + locale
// Pattern: /src/calculators/{category}/{slug}/content/{locale}.mdx
const mdxKey = `/src/calculators/${cat}/${calc.slug}/content/${locale}.mdx`;
const fallbackMdxKey = `/src/calculators/${cat}/${calc.slug}/content/en.mdx`;

const mdxModule = allMdxModules[mdxKey] ?? allMdxModules[fallbackMdxKey];

// Extract the Content component from the MDX module
const Content = mdxModule
  ? (mdxModule as { Content?: unknown }).Content ?? (mdxModule as { default?: unknown }).default
  : null;
---

<Base
  locale={locale}
  title={bundle.title}
  description={seo.description}
  canonical={seo.canonical}
>
  <!-- Hreflang alternate links -->
  {hreflangs.map((entry) => (
    <link
      rel="alternate"
      hreflang={entry.hreflang}
      href={entry.href}
      slot="head"
    />
  ))}

  <!-- SEO keywords -->
  {seo.keywords && seo.keywords.length > 0 && (
    <meta
      name="keywords"
      content={seo.keywords.join(", ")}
      slot="head"
    />
  )}

  <!-- OG image for social sharing and AI/LLM discovery (D2) -->
  {seo.ogImage && (
    <meta property="og:image" content={seo.ogImage} slot="head" />
  )}
  {seo.ogImage && (
    <meta name="twitter:image" content={seo.ogImage} slot="head" />
  )}

  <main>
    <!-- Page header with breadcrumb -->
    <div class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
      <div class="container-page py-6">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-3 text-sm text-slate-500 dark:text-slate-400">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li>
              <a
                href={`${import.meta.env.BASE_URL}${locale}/`}
                class="hover:text-slate-800 dark:hover:text-slate-200"
              >
                {t(locale, "nav.home")}
              </a>
            </li>
            <li aria-hidden="true">/</li>
            <li>
              <a
                href={buildAbsoluteUrl(locale, cat).replace(SITE_URL, "")}
                class="hover:text-slate-800 dark:hover:text-slate-200"
              >
                {categoryLabel}
              </a>
            </li>
            <li aria-hidden="true">/</li>
            <li>
              <span
                class="font-medium text-slate-900 dark:text-slate-100"
                aria-current="page"
              >
                {bundle.title}
              </span>
            </li>
          </ol>
        </nav>

        <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-3xl break-words">
          {bundle.title}
        </h1>
        {bundle.description && (
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 max-w-2xl">
            {bundle.description}
          </p>
        )}
      </div>
    </div>

    <!-- Content layout (sidebar removed — was too space-greedy on desktop
         and pushed the calculator below the fold on tablets). Category
         + related-calc nav lives in Header (desktop) and the hamburger
         drawer (mobile). -->
    <div class="container-page py-6">
      <div class="min-w-0">
        <!-- Quick Answer block (A2 SEO) — above the calculator form -->
        <QuickAnswer calc={calc} locale={locale} />

        <!-- CalculatorView island -->
        <div class="rounded-xl bg-slate-50 dark:bg-slate-900/50 py-2">
          <CalculatorIsland
            client:only="react"
            slug={calc.slug}
            locale={locale}
            compareLabels={{
              toggle: t(locale, "compare.toggle"),
              scenarioA: t(locale, "compare.scenarioA"),
              scenarioB: t(locale, "compare.scenarioB"),
              difference: t(locale, "compare.difference"),
              exitCompare: t(locale, "compare.exitCompare"),
              deltaLabel: t(locale, "compare.deltaLabel"),
            }}
            nlLabels={{
              toggle: t(locale, "nl.toggle"),
              placeholder: t(locale, "nl.placeholder"),
              fill: t(locale, "nl.fill"),
              matched: t(locale, "nl.matched"),
              unmatched: t(locale, "nl.unmatched"),
            }}
          />
        </div>

        <!-- Universal per-calc visualization slot — auto-loads any
             visualizations.tsx file present for this calculator. -->
        <CalcVizSlot client:only="react" slug={calc.slug} locale={locale} />

        <!-- MDX content -->
        {Content && (
          <section
            class="py-10 prose prose-slate dark:prose-invert max-w-none"
            aria-label="Calculator guide"
          >
            {/* @ts-ignore — Astro MDX Content component is dynamic */}
            <Content />
          </section>
        )}

        <!-- Authority & Trust footer (A1 SEO / E-E-A-T) -->
        <AuthorityFooter calc={calc} locale={locale} />

        <!-- Related calculators -->
        {relatedCalcs.length > 0 && (
          <section class="py-10 border-t border-slate-200 dark:border-slate-700">
            <h2 class="mb-6 text-xl font-semibold text-slate-900 dark:text-slate-100">
              {t(locale, "labels.related")}
            </h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
              {relatedCalcs.map((rel) => {
                const relBundle = rel.i18n[locale] ?? rel.i18n["en"];
                const relSlug = getLocalizedSlug(rel.slug, locale);
                const relHref = `${import.meta.env.BASE_URL}${locale}/${rel.category}/${relSlug}/`;
                return (
                  <a
                    href={relHref}
                    class="group rounded-lg border border-slate-200 bg-white p-4 text-sm shadow-sm hover:border-blue-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-600"
                  >
                    <div class="font-medium text-slate-900 group-hover:text-blue-700 dark:text-slate-100 dark:group-hover:text-blue-400">
                      {relBundle.title}
                    </div>
                    <div class="mt-1 text-slate-500 dark:text-slate-400 line-clamp-2">
                      {relBundle.short}
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}
      </div>
    </div>
  </main>

  <!-- JSON-LD structured data: SoftwareApplication + BreadcrumbList -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- JSON-LD: HowTo (math / conversion / engineering / formula calcs) -->
  {howToJsonLd && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(howToJsonLd)}
    />
  )}

  <!-- JSON-LD: FAQPage (calcs with faq[] bundle) -->
  {faqJsonLd && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(faqJsonLd)}
    />
  )}
</Base>
