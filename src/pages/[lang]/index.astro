---
import Base from "@/layouts/Base.astro";
import { LOCALES, isLocale, type Locale } from "@/config/site";
import { t, buildAbsoluteUrl } from "@/lib/i18n";
import { getAvailableCategories } from "@/lib/registry";
import { getCategoryLabel } from "@/lib/i18n";

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!lang || !isLocale(lang)) {
  return Astro.redirect("/numio/en/");
}
const locale = lang as Locale;
const categories = getAvailableCategories();
const canonical = buildAbsoluteUrl(locale);
---

<Base locale={locale} canonical={canonical}>
  <main class="container-page py-16">
    <header class="mb-12 text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl text-balance">
        {t(locale, "site.name")}
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 text-balance">
        {t(locale, "site.tagline")}
      </p>
    </header>

    {categories.length === 0 ? (
      <section class="card mx-auto max-w-2xl text-center">
        <h2 class="text-xl font-semibold">
          {t(locale, "labels.loading")}
        </h2>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
          Calculators will appear here as they are added. (Phase 0 scaffold — no calculators yet.)
        </p>
      </section>
    ) : (
      <section class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat) => (
          <a
            href={`${import.meta.env.BASE_URL}${locale}/${cat}/`}
            class="card transition-shadow hover:shadow-md"
          >
            <h2 class="text-xl font-semibold capitalize">
              {getCategoryLabel(locale, cat)}
            </h2>
          </a>
        ))}
      </section>
    )}

    <footer class="mt-24 border-t border-slate-200 pt-8 text-center text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400">
      <p>{t(locale, "footer.copyright")}</p>
    </footer>
  </main>
</Base>
