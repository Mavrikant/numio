---
/**
 * Tools listing page — /calculators/{lang}/tools/
 */
import Base from "@/layouts/Base.astro";
import { LOCALES, isLocale, type Locale, SITE_URL } from "@/config/site";
import { t } from "@/lib/i18n";
import { getAllTools } from "@/lib/tools-registry";

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!lang || !isLocale(lang)) {
  return Astro.redirect("/calculators/en/");
}
const locale = lang as Locale;

const tools = getAllTools();
const canonical = `${SITE_URL}/calculators/${locale}/tools/`;
const title = t(locale, "nav.tools") ?? "Data Analysis Tools";
const description = t(locale, "tools.description") ??
  "Upload CSV data and create interactive visualizations — histograms, scatter plots, time series, and descriptive statistics.";
---

<Base locale={locale} title={title} description={description} canonical={canonical}>
  {LOCALES.map((l) => (
    <link
      rel="alternate"
      hreflang={l}
      href={`${SITE_URL}/calculators/${l}/tools/`}
      slot="head"
    />
  ))}

  <main>
    <div class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
      <div class="container-page py-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">{title}</h1>
        <p class="mt-2 max-w-2xl text-slate-600 dark:text-slate-400">{description}</p>
      </div>
    </div>

    <div class="container-page py-8">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => {
          const bundle = tool.i18n[locale] ?? tool.i18n["en"];
          const href = `${import.meta.env.BASE_URL}${locale}/tools/${tool.slug}/`;
          return (
            <a
              href={href}
              class="group rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:border-blue-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-600"
            >
              <div class="text-lg font-semibold text-slate-900 group-hover:text-blue-700 dark:text-slate-100 dark:group-hover:text-blue-400">
                {bundle.title}
              </div>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-3">
                {bundle.short}
              </p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {tool.tags.slice(0, 3).map((tag) => (
                  <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-400">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>
</Base>
