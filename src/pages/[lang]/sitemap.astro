---
/**
 * Human-readable sitemap — /numio/{lang}/sitemap/
 *
 * Lists every calculator (grouped by category) and every tool
 * (grouped by tool category) in one place, with localized links.
 */
import Base from "@/layouts/Base.astro";
import { LOCALES, isLocale, type Locale, SITE_NAME } from "@/config/site";
import {
  t,
  buildPath,
  buildAbsoluteUrl,
  getCategoryLabel,
  getLocalizedSlug,
} from "@/lib/i18n";
import {
  getAvailableCategories,
  getCalculatorsByCategory,
} from "@/lib/registry";
import { getAllTools } from "@/lib/tools-registry";
import type { ToolCategory } from "@/types/tool";

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!lang || !isLocale(lang)) {
  return Astro.redirect("/numio/en/");
}
const locale = lang as Locale;

const canonical = buildAbsoluteUrl(locale, "sitemap");
const title = t(locale, "sitemap.title");
const description = t(locale, "sitemap.description");

// Calculators grouped by category.
const calcCategories = getAvailableCategories().map((cat) => ({
  cat,
  label: getCategoryLabel(locale, cat),
  items: getCalculatorsByCategory(cat).map((calc) => ({
    title: (calc.i18n[locale] ?? calc.i18n["en"]).title,
    href: buildPath(locale, cat, getLocalizedSlug(calc.slug, locale)),
  })),
}));

// Tools grouped by tool category.
const toolGroups = new Map<ToolCategory, ToolDefinitionEntry[]>();
interface ToolDefinitionEntry {
  title: string;
  href: string;
}
for (const tool of getAllTools()) {
  const bundle = tool.i18n[locale] ?? tool.i18n["en"];
  const entry: ToolDefinitionEntry = {
    title: bundle.title,
    href: buildPath(locale, "tools", tool.slug),
  };
  const arr = toolGroups.get(tool.category) ?? [];
  arr.push(entry);
  toolGroups.set(tool.category, arr);
}
const toolCategories = [...toolGroups.entries()].map(([cat, items]) => ({
  cat,
  label: getCategoryLabel(locale, cat),
  items,
}));
---

<Base locale={locale} title={title} description={description} canonical={canonical}>
  {LOCALES.map((l) => (
    <link
      rel="alternate"
      hreflang={l}
      href={buildAbsoluteUrl(l, "sitemap")}
      slot="head"
    />
  ))}

  <main class="container-page py-8">
    <div class="min-w-0">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-slate-500 dark:text-slate-400">
        <ol class="flex items-center gap-2">
          <li>
            <a
              href={buildPath(locale)}
              class="hover:text-slate-800 dark:hover:text-slate-200"
            >
              {t(locale, "nav.home")}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <span class="font-medium text-slate-900 dark:text-slate-100" aria-current="page">
              {title}
            </span>
          </li>
        </ol>
      </nav>

      <header class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-4xl">
          {title}
        </h1>
        <p class="mt-2 max-w-2xl text-slate-600 dark:text-slate-400">{description}</p>
      </header>

      {calcCategories.length > 0 && (
        <section class="mb-12">
          <h2 class="mb-6 text-xl font-semibold text-slate-900 dark:text-slate-100">
            {t(locale, "nav.categories")}
          </h2>
          <div class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
            {calcCategories.map((group) => (
              <div>
                <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
                  <a
                    href={buildPath(locale, group.cat)}
                    class="hover:text-slate-900 dark:hover:text-slate-100"
                  >
                    {group.label}
                  </a>
                </h3>
                <ul class="flex flex-col gap-2" role="list">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="text-sm text-slate-600 hover:text-blue-700 dark:text-slate-400 dark:hover:text-blue-400 transition-colors"
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}

      {toolCategories.length > 0 && (
        <section>
          <h2 class="mb-6 text-xl font-semibold text-slate-900 dark:text-slate-100">
            <a
              href={buildPath(locale, "tools")}
              class="hover:text-blue-700 dark:hover:text-blue-400"
            >
              {t(locale, "nav.tools")}
            </a>
          </h2>
          <div class="grid grid-cols-1 gap-x-8 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
            {toolCategories.map((group) => (
              <div>
                <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
                  {group.label}
                </h3>
                <ul class="flex flex-col gap-2" role="list">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="text-sm text-slate-600 hover:text-blue-700 dark:text-slate-400 dark:hover:text-blue-400 transition-colors"
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: SITE_NAME,
          item: buildAbsoluteUrl(locale),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title,
          item: canonical,
        },
      ],
    })}
  />
</Base>
