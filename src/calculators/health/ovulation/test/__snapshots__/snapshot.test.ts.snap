    "zh": {
      "description": "免费排卵计算器。输入您的末次月经日期和平均周期长度，即可估算受孕窗口、排卵日期、LH峰值及下次月经日期。",
      "errors": {
        "cycleLengthOutOfRange": "周期长度必须在21至45天之间。",
        "invalidDate": "请输入格式为YYYY-MM-DD的有效日期。",
      },
      "faq": [
        {
          "a": "排卵通常发生在下次月经前14天。由于精子可存活最多5天，受孕窗口从排卵前5天延伸至排卵后1天。",
          "q": "受孕窗口是如何计算的？",
        },
        {
          "a": "促黄体生成素（LH）峰值在24–36小时内触发排卵，排卵测试可在尿液中检测到这一峰值。",
          "q": "什么是LH峰值？",
        },
      ],
      "inputs": {
        "cycleLength": {
          "help": "从一次月经第一天到下一次月经第一天的天数。平均28天（范围：21–45天）。",
          "label": "平均周期长度（天）",
        },
        "lmpDate": {
          "help": "您最近一次月经的第一天。",
          "label": "末次月经日期（LMP）",
        },
      },
      "keywords": [
        "排卵计算器",
        "受孕窗口",
        "排卵日期",
        "何时排卵",
        "月经周期",
        "怀孕计划",
        "生育期计算",
      ],
      "outputs": {
        "fertileEnd": {
          "help": "排卵后第二天——卵子大约存活24小时。",
          "label": "受孕窗口结束",
        },
        "fertileStart": {
          "help": "精子可存活最多5天，因此受孕窗口从排卵前5天开始。",
          "label": "受孕窗口开始",
        },
        "lhSurgeDate": {
          "help": "排卵前一天，排卵测试通常在此时检测到促黄体生成素峰值。",
          "label": "LH峰值（预测）",
        },
        "nextPeriod": {
          "help": "您下次月经预测开始日期。",
          "label": "下次月经（预测）",
        },
        "ovulationDate": {
          "help": "您的卵巢最可能释放卵子的那一天。",
          "label": "预测排卵日期",
        },
      },
      "short": "根据您的月经周期，找出最易受孕的天数和预测排卵日期。",
      "title": "排卵期和受孕窗口计算器",
    },
