      },
      "short": "Devine, Robinson, Miller ve Hamwi formülleriyle ideal vücut ağırlığınızı hesaplayın.",
      "title": "İdeal Kilo Hesaplayıcı",
    },
    "zh": {
      "description": "免费理想体重计算器，采用Devine、Robinson、Miller和Hamwi四种公式。输入您的身高和性别，获取四种循证方程计算的理想体重范围。",
      "errors": {
        "heightOutOfRange": "身高必须在50至250厘米（或20至100英寸）之间。",
      },
      "faq": [
        {
          "a": "这四种公式最初都不是为一般人群定义"健康"体重而设计的——它们是在临床环境中为药物剂量计算而开发的。对于一般健康评估，BMI和体成分测量更为相关。",
          "q": "哪种理想体重公式最准确？",
        },
      ],
      "inputs": {
        "gender": {
          "help": "性别用于公式常数。",
          "label": "生理性别",
        },
        "height": {
          "help": "您的身高，以厘米（公制）或英寸（英制）为单位。",
          "label": "身高",
        },
        "unit": {
          "help": "选择公制（厘米）或英制（英寸）。",
          "label": "单位制",
        },
      },
      "keywords": [
        "理想体重计算器",
        "理想身体重量",
        "Devine公式",
        "Robinson公式",
        "IBW计算器",
        "健康体重",
        "身高对应体重",
      ],
      "options": {
        "gender": {
          "female": "女性",
          "male": "男性",
        },
        "unit": {
          "imperial": "英制（英寸）",
          "metric": "公制（厘米）",
        },
      },
      "outputs": {
        "devine": {
          "help": "临床药理学中最常用于药物剂量计算的公式。",
          "label": "Devine（1974年）",
          "suffix": "千克",
        },
        "hamwi": {
          "help": "Hamwi公式——四种中最古老，常用于营养学。",
          "label": "Hamwi（1964年）",
          "suffix": "千克",
        },
        "miller": {
          "help": "Miller公式——通常给出略高的估算值。",
          "label": "Miller（1983年）",
          "suffix": "千克",
        },
        "robinson": {
          "help": "Robinson公式——针对现代人群的更新估算。",
          "label": "Robinson（1983年）",
          "suffix": "千克",
        },
      },
      "short": "使用4种经过验证的公式计算您的理想体重——Devine、Robinson、Miller和Hamwi。",
      "title": "理想体重计算器",
    },
  },
