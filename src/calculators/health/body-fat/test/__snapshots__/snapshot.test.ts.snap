          "help": "Kalça ve popo bölgesinin en geniş noktasında ölçün. Yalnızca kadınlar için gereklidir.",
          "label": "Kalça çevresi (kadınlar)",
        },
        "neck": {
          "help": "Larinksin (Adem elması) hemen altından, hafifçe aşağıya doğru eğimli ölçün.",
          "label": "Boyun çevresi",
        },
        "waist": {
          "help": "Erkekler için göbek hizasında, kadınlar için belin en ince noktasında ölçün.",
          "label": "Bel çevresi",
        },
        "weight": {
          "help": "Yağ ve kas kütlesini hesaplamak için kullanılan vücut ağırlığınız.",
          "label": "Kilo",
        },
      },
      "keywords": [
