  "inputs": [
    {
      "defaultValue": "male",
      "id": "gender",
      "required": true,
      "type": {
        "kind": "select",
        "options": [
          {
            "i18nKey": "male",
            "value": "male",
          },
          {
            "i18nKey": "female",
            "value": "female",
          },
        ],
      },
    },
    {
      "defaultValue": 175,
      "id": "height",
      "required": true,
      "type": {
        "kind": "number",
        "max": 250,
        "min": 50,
        "step": 0.5,
        "unit": "cm",
      },
    },
    {
      "defaultValue": 75,
      "id": "weight",
      "required": true,
      "type": {
        "kind": "number",
        "max": 300,
        "min": 1,
        "step": 0.1,
        "unit": "kg",
      },
    },
    {
      "defaultValue": 85,
      "id": "waist",
      "required": true,
      "type": {
        "kind": "number",
        "max": 200,
        "min": 30,
        "step": 0.5,
        "unit": "cm",
      },
    },
    {
      "defaultValue": 37,
      "id": "neck",
      "required": true,
      "type": {
        "kind": "number",
        "max": 80,
        "min": 20,
        "step": 0.5,
        "unit": "cm",
      },
    },
    {
      "defaultValue": 95,
      "id": "hip",
      "required": false,
      "type": {
        "kind": "number",
        "max": 200,
        "min": 50,
        "step": 0.5,
        "unit": "cm",
      },
    },
  ],
  "meta": {
    "disclaimer": "The US Navy tape method estimates body fat percentage from circumference measurements. It is less accurate than DEXA or hydrostatic weighing but is a practical field assessment tool.",
    "formulaLatex": "\\%BF_{\\text{male}} = 86.01\\log_{10}(\\text{waist}-\\text{neck}) - 70.041\\log_{10}(\\text{height}) + 36.76",
    "references": [
      {
        "authority": "Naval Health Research Center",
        "title": "Hodgdon JA, Beckett MB (1984). Prediction of percent body fat for US Navy personnel.",
      },
      {
        "authority": "United States Navy",
        "title": "US Navy Body Composition Assessment",
        "url": "https://www.public.navy.mil/",
      },
    ],
  },
  "outputs": [
    {
      "format": "percent",
      "highlight": true,
      "id": "bodyFatPct",
      "precision": 1,
    },
    {
      "format": "number",
      "id": "fatMass",
      "precision": 1,
      "unit": "kg",
    },
    {
      "format": "number",
      "id": "leanMass",
      "precision": 1,
      "unit": "kg",
    },
    {
      "format": "text",
      "id": "category",
    },
  ],
