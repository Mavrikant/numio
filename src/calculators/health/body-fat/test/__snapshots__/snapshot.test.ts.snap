          "label": "Обхват бёдер (женщины)",
        },
        "neck": {
          "help": "Измеряется чуть ниже гортани, с небольшим наклоном вниз.",
          "label": "Обхват шеи",
        },
        "waist": {
          "help": "Измеряется на уровне пупка (мужчины) или в самой узкой части (женщины).",
          "label": "Обхват талии",
        },
        "weight": {
          "help": "Ваш вес в килограммах, используется для расчёта жировой и мышечной массы.",
          "label": "Масса тела",
        },
      },
      "keywords": [
