        "category": {
          "help": "ACE (Amerikan Egzersiz Konseyi) vücut yağ sınıflandırması.",
          "label": "Kategori",
        },
        "fatMass": {
          "help": "Tahmini vücut yağı ağırlığı (kg).",
          "label": "Yağ kütlesi",
          "suffix": "kg",
        },
        "leanMass": {
          "help": "Vücut ağırlığı eksi yağ kütlesi — kas, kemik, su ve organları içerir.",
          "label": "Yağsız kütle",
          "suffix": "kg",
        },
      },
      "short": "ABD Donanması çevre ölçümü yöntemiyle vücut yağ yüzdenizi tahmin edin.",
      "title": "Vücut Yağ Oranı Hesaplayıcı",
    },
    "zh": {
      "description": "免费体脂率计算器，采用美国海军围度法（Hodgdon & Beckett，1984年）。输入颈围、腰围和臀围，无需专业设备即可获得准确估算。",
      "errors": {
        "heightOutOfRange": "身高必须在50至250厘米之间。",
        "hipRequired": "女性需要提供臀围数据。",
        "waistMustExceedNeck": "腰围必须大于颈围。",
        "weightOutOfRange": "体重必须在1至300千克之间。",
      },
      "faq": [
        {
          "a": "美国海军围度法的准确度通常在±3-4个百分点以内（与DEXA相比）。它比BMI更准确，但不如水下称重或DEXA精确。",
          "q": "美国海军法有多准确？",
        },
      ],
      "inputs": {
        "gender": {
          "help": "女性公式需要臀围数据。",
          "label": "生理性别",
        },
        "height": {
          "help": "您的身高（厘米）。",
          "label": "身高",
        },
        "hip": {
          "help": "在臀部和臀部最宽处测量。仅女性需要。",
          "label": "臀围（女性）",
        },
        "neck": {
          "help": "在喉结正下方稍微向下倾斜处测量。",
          "label": "颈围",
        },
        "waist": {
          "help": "男性在肚脐处测量，女性在腰部最细处测量。",
          "label": "腰围",
        },
        "weight": {
          "help": "您的体重（千克），用于计算脂肪质量和瘦体重。",
          "label": "体重",
        },
      },
      "keywords": [
        "体脂率计算器",
        "体脂百分比",
        "美国海军法",
        "围度法",
        "瘦体重",
        "脂肪质量",
        "身体成分",
      ],
      "options": {
        "gender": {
          "female": "女性",
          "male": "男性",
        },
      },
      "outputs": {
        "bodyFatPct": {
          "help": "体重中脂肪占比的估算值。",
          "label": "体脂率",
        },
        "category": {
          "help": "美国运动委员会（ACE）的体脂分类。",
          "label": "分类",
        },
        "fatMass": {
          "help": "体脂的估算重量（千克）。",
          "label": "脂肪质量",
          "suffix": "千克",
        },
        "leanMass": {
          "help": "体重减去脂肪质量——包括肌肉、骨骼、水分和器官。",
          "label": "瘦体重",
          "suffix": "千克",
        },
      },
      "short": "使用美国海军围度法估算您的体脂率。",
      "title": "体脂率计算器",
    },
  },
