          "suffix": "kg",
        },
        "expectedGainAtWeek": {
          "help": "Valore mediano dell'aumento IOM raccomandato per la tua settimana gestazionale.",
          "label": "Aumento atteso a questa settimana",
          "suffix": "kg",
        },
        "onTrack": {
          "help": "Se il tuo aumento di peso attuale è nell'intervallo atteso.",
