          "loseFast": "Hızlı kilo ver (~1 kg/hafta)",
          "maintain": "Kiloyu koru",
        },
      },
      "outputs": {
        "deficit": {
          "help": "Pozitif = kalori fazlası (kilo almak için). Negatif = kalori açığı (kilo vermek için).",
          "label": "Günlük fazla / açık",
          "suffix": "kcal/gün",
        },
        "target": {
          "help": "Seçilen hedefe ulaşmak için önerilen günlük kalori alımı.",
          "label": "Hedef kalori",
          "suffix": "kcal/gün",
        },
        "tdee": {
          "help": "Mevcut kilonuzu korumak için gereken günlük kalori.",
          "label": "İdame kalorileri (TDEE)",
          "suffix": "kcal/gün",
        },
      },
      "short": "Günlük kalori ihtiyacınızı (TDEE) hesaplayın ve kilo hedefinize göre hedef belirleyin.",
      "title": "Kalori Hesaplayıcı",
    },
    "zh": {
      "description": "基于Mifflin-St Jeor公式的免费TDEE计算器。输入您的数据和活动水平，了解维持体重所需的卡路里，并根据目标进行调整。",
      "errors": {
        "ageOutOfRange": "年龄必须在1至120岁之间。",
        "heightOutOfRange": "身高必须在50至250厘米之间。",
        "weightOutOfRange": "体重必须在1至300千克之间。",
      },
      "faq": [
        {
          "a": "每日总能量消耗（TDEE）是您一天内消耗的卡路里总量，包括基础代谢率和体力活动。摄入量等于TDEE时体重保持稳定。",
          "q": "什么是TDEE？",
        },
        {
          "a": "大多数指南建议每周减重不超过0.5-1千克，以避免肌肉流失和代谢减慢。",
          "q": "安全的减重速度是多少？",
        },
      ],
      "inputs": {
        "activity": {
          "help": "选择最能反映您日常活动量的级别。",
          "label": "活动水平",
        },
        "age": {
          "help": "您的年龄（岁）。",
          "label": "年龄",
        },
        "gender": {
          "help": "性别通过肌肉量和激素差异影响基础代谢率。",
          "label": "生理性别",
        },
        "goal": {
          "help": "选择您的体重目标。",
          "label": "目标",
        },
        "height": {
          "help": "您的身高（厘米）。",
          "label": "身高",
        },
        "weight": {
          "help": "您当前的体重（千克）。",
          "label": "体重",
        },
      },
      "keywords": [
        "卡路里计算器",
        "TDEE计算器",
        "每日卡路里需求",
        "卡路里赤字",
        "维持卡路里",
        "减肥卡路里",
        "能量消耗",
      ],
      "options": {
        "activity": {
          "active": "高度活跃（每周6-7天）",
          "light": "轻度活跃（每周1-3天）",
          "moderate": "中度活跃（每周3-5天）",
          "sedentary": "久坐不动（办公室工作，几乎不运动）",
          "veryActive": "极度活跃（体力工作或双倍训练）",
        },
        "gender": {
          "female": "女性",
          "male": "男性",
        },
        "goal": {
          "gain": "增重（约0.5千克/周）",
          "gainFast": "快速增重（约1千克/周）",
          "lose": "减重（约0.5千克/周）",
          "loseFast": "快速减重（约1千克/周）",
          "maintain": "维持体重",
        },
      },
      "outputs": {
        "deficit": {
          "help": "正值=卡路里盈余。负值=卡路里赤字。",
          "label": "每日盈余/赤字",
          "suffix": "千卡/天",
        },
        "target": {
          "help": "实现所选目标的推荐每日摄入量。",
          "label": "目标卡路里",
          "suffix": "千卡/天",
        },
        "tdee": {
          "help": "维持当前体重所需的每日卡路里。",
          "label": "维持卡路里（TDEE）",
          "suffix": "千卡/天",
        },
      },
      "short": "计算您的每日卡路里需求（TDEE），并根据体重目标设定摄入量。",
      "title": "卡路里计算器",
    },
  },
