          "help": "速度（米/秒）。",
          "label": "米/秒 (m/s)",
        },
        "result": {
          "help": "转换后的速度值。",
          "label": "结果",
        },
      },
      "short": "转换不同的速度单位：公里/小时、英里/小时、米/秒、节和英尺/秒。",
      "title": "速度转换器",
    },
