          "knots": "노트",
          "mph": "mph",
          "ms": "m/s",
        },
        "toUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "노트",
          "mph": "mph",
          "ms": "m/s",
        },
      },
      "outputs": {
        "fts": {
          "help": "초당 피트 단위의 속도입니다.",
          "label": "초당 피트 (ft/s)",
        },
        "kmh": {
          "help": "시간당 킬로미터 단위의 속도입니다.",
          "label": "시간당 킬로미터 (km/h)",
        },
        "knots": {
          "help": "노트 단위의 속도입니다.",
          "label": "노트",
