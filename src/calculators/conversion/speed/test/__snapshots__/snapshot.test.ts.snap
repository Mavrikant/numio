    "zh": {
      "description": "免费速度单位转换器。转换公里/小时、英里/小时、米/秒、节和英尺/秒。实时转换速度测量。",
      "errors": {},
      "faq": [
        {
          "a": "公里/小时（km/h）以小时为单位测量公里距离，而英里/小时（mph）以小时为单位测量英里距离。1英里/小时≈1.609公里/小时。",
          "q": "公里/小时和英里/小时有什么区别？",
        },
        {
          "a": "节（每小时海里）主要用于海事和航空导航，用于测量船舶和飞机的速度。1节=1.852公里/小时。",
          "q": "节用在哪里？",
        },
        {
          "a": "1米/秒约等于3.6公里/小时、2.237英里/小时、1.944节或3.281英尺/秒。",
          "q": "1米/秒等于其他单位中的多少？",
        },
        {
          "a": "要将英尺/秒转换为公里/小时，请将英尺/秒的值乘以1.09728。例如，10英尺/秒=10×1.09728=10.9728公里/小时。",
          "q": "如何将英尺/秒转换为公里/小时？",
        },
      ],
      "inputs": {
        "fromUnit": {
          "help": "选择要转换的数值的单位。",
          "label": "从",
        },
        "toUnit": {
          "help": "选择要转换到的单位。",
          "label": "至",
        },
        "value": {
          "help": "输入要转换的速度值。",
          "label": "数值",
        },
      },
      "keywords": [
        "速度转换器",
        "速度单位",
        "公里每小时到英里每小时",
        "速度转换",
        "节转换",
        "速度测量",
      ],
      "options": {
        "fromUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "节",
          "mph": "mph",
          "ms": "m/s",
        },
        "toUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "节",
          "mph": "mph",
          "ms": "m/s",
        },
      },
      "outputs": {
        "fts": {
          "help": "速度（英尺/秒）。",
          "label": "英尺/秒 (ft/s)",
        },
        "kmh": {
          "help": "速度（公里/小时）。",
          "label": "公里/小时 (km/h)",
        },
        "knots": {
