      "errors": {},
      "faq": [
        {
          "a": "I chilometri all'ora (km/h) misurano la distanza in chilometri in un'ora, mentre le miglia all'ora (mph) misurano la distanza in miglia in un'ora. 1 mph ≈ 1.609 km/h.",
          "q": "Qual è la differenza tra km/h e mph?",
        },
        {
          "a": "I nodi (miglia nautiche all'ora) sono utilizzati principalmente nella navigazione marittima e aerea per misurare la velocità di navi e aerei. 1 nodo = 1.852 km/h.",
          "q": "A cosa servono i nodi?",
        },
        {
          "a": "1 m/s equivale approssimativamente a 3.6 km/h, 2.237 mph, 1.944 nodi o 3.281 ft/s.",
          "q": "Quanto è 1 m/s in altre unità?",
        },
        {
          "a": "Per convertire piedi al secondo in chilometri all'ora, moltiplica il valore in ft/s per 1.09728. Ad esempio, 10 ft/s = 10 × 1.09728 = 10.9728 km/h.",
          "q": "Come converto ft/s in km/h?",
        },
      ],
      "inputs": {
        "fromUnit": {
          "help": "Seleziona l'unità del valore che stai convertendo.",
          "label": "Da",
        },
        "toUnit": {
          "help": "Seleziona l'unità in cui desideri convertire.",
          "label": "A",
        },
        "value": {
          "help": "Inserisci il valore di velocità che desideri convertire.",
          "label": "Valore",
        },
      },
      "keywords": [
        "convertitore di velocità",
        "unità di velocità",
        "km/h in mph",
        "convertitore di velocità",
        "convertitore di nodi",
        "misurazione della velocità",
      ],
      "options": {
        "fromUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "nodi",
          "mph": "mph",
          "ms": "m/s",
        },
        "toUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "nodi",
          "mph": "mph",
          "ms": "m/s",
        },
      },
      "outputs": {
        "fts": {
          "help": "Velocità in piedi al secondo.",
          "label": "Piedi al secondo (ft/s)",
        },
        "kmh": {
          "help": "Velocità in chilometri all'ora.",
          "label": "Chilometri all'ora (km/h)",
        },
        "knots": {
          "help": "Velocità in nodi.",
          "label": "Nodi",
        },
        "mph": {
          "help": "Velocità in miglia all'ora.",
          "label": "Miglia all'ora (mph)",
        },
        "ms": {
          "help": "Velocità in metri al secondo.",
          "label": "Metri al secondo (m/s)",
        },
        "result": {
          "help": "Il valore di velocità convertito.",
          "label": "Risultato",
        },
      },
      "short": "Converti tra diverse unità di velocità: km/h, mph, m/s, nodi e ft/s.",
      "title": "Convertitore di Velocità",
    },
    "ja": {
      "description": "無料の速度単位コンバーター。時速キロメートル、時速マイル、メートル毎秒、ノット、フィート毎秒の間で変換します。速度測定のリアルタイム変換。",
      "errors": {},
      "faq": [
        {
          "a": "時速キロメートル（km/h）は1時間でのキロメートル距離を測定し、時速マイル（mph）は1時間でのマイル距離を測定します。1 mph≈1.609 km/h。",
          "q": "km/hとmphの違いは何ですか？",
        },
        {
          "a": "ノット（時速海里）は主に海事および航空ナビゲーションで船舶と航空機の速度を測定するために使用されます。1ノット=1.852 km/h。",
          "q": "ノットは何に使われますか？",
        },
        {
          "a": "1 m/sはおよそ3.6 km/h、2.237 mph、1.944ノット、または3.281 ft/sに相当します。",
          "q": "1 m/sは他の単位でいくらですか？",
        },
        {
          "a": "フィート毎秒をキロメートル毎時に変換するには、ft/sの値に1.09728を乗算します。例えば、10 ft/s = 10 × 1.09728 = 10.9728 km/h。",
          "q": "ft/sをkm/hに変換するにはどうしますか？",
        },
      ],
      "inputs": {
        "fromUnit": {
          "help": "変換する値の単位を選択します。",
          "label": "から",
        },
        "toUnit": {
          "help": "変換先の単位を選択します。",
          "label": "へ",
        },
        "value": {
          "help": "変換する速度値を入力します。",
          "label": "値",
        },
      },
      "keywords": [
        "速度コンバーター",
        "速度単位",
        "km/hからmph",
        "速度変換",
        "ノットコンバーター",
        "速度測定",
      ],
      "options": {
        "fromUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "ノット",
          "mph": "mph",
          "ms": "m/s",
        },
        "toUnit": {
          "fts": "ft/s",
          "kmh": "km/h",
          "knots": "ノット",
          "mph": "mph",
          "ms": "m/s",
        },
      },
      "outputs": {
        "fts": {
          "help": "フィート毎秒単位の速度。",
          "label": "フィート毎秒 (ft/s)",
        },
        "kmh": {
          "help": "時速キロメートル単位の速度。",
          "label": "時速キロメートル (km/h)",
        },
        "knots": {
          "help": "ノット単位の速度。",
          "label": "ノット",
        },
        "mph": {
          "help": "時速マイル単位の速度。",
          "label": "時速マイル (mph)",
        },
        "ms": {
          "help": "メートル毎秒単位の速度。",
          "label": "メートル毎秒 (m/s)",
        },
        "result": {
          "help": "変換後の速度値。",
          "label": "結果",
        },
      },
      "short": "異なる速度単位を変換：時速キロメートル、時速マイル、メートル毎秒、ノット、フィート毎秒。",
      "title": "速度コンバーター",
    },
    "ko": {
      "description": "무료 속도 단위 변환기입니다. km/h, mph, m/s, 노트, ft/s 간에 변환하세요. 속도 측정을 위한 실시간 변환입니다.",
      "errors": {},
      "faq": [
        {
          "a": "시간당 킬로미터(km/h)는 1시간 동안의 킬로미터 거리를 측정하고, 시간당 마일(mph)은 1시간 동안의 마일 거리를 측정합니다. 1 mph ≈ 1.609 km/h.",
          "q": "km/h와 mph의 차이는 무엇입니까?",
        },
        {
          "a": "노트(시간당 해리)는 주로 해상 및 항공 항법에서 선박과 항공기의 속도를 측정하는 데 사용됩니다. 1 노트 = 1.852 km/h.",
          "q": "노트는 무엇에 사용되나요?",
        },
        {
          "a": "1 m/s는 약 3.6 km/h, 2.237 mph, 1.944 노트, 또는 3.281 ft/s와 같습니다.",
          "q": "1 m/s는 다른 단위로 얼마입니까?",
        },
        {
          "a": "초당 피트를 시간당 킬로미터로 변환하려면 ft/s 값에 1.09728을 곱합니다. 예를 들어, 10 ft/s = 10 × 1.09728 = 10.9728 km/h.",
          "q": "ft/s를 km/h로 변환하려면 어떻게 해야 합니까?",
        },
      ],
      "inputs": {
        "fromUnit": {
          "help": "변환하는 값의 단위를 선택하세요.",
          "label": "다음에서",
        },
        "toUnit": {
          "help": "변환할 단위를 선택하세요.",
          "label": "다음으로",
        },
        "value": {
          "help": "변환할 속도 값을 입력하세요.",
          "label": "값",
        },
      },
      "keywords": [
