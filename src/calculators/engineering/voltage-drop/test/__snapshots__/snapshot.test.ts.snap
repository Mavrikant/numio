        "receivingVoltage": {
          "help": "Фактическое напряжение, доступное нагрузке.",
          "label": "Напряжение у нагрузки (В)",
        },
        "recommendation": {
          "help": "ok = ≤3%, предупреждение = 3–5%, критично = >5%.",
          "label": "Статус NEC",
        },
        "voltageDrop": {
          "help": "Суммарные потери напряжения на обоих проводниках (туда и обратно).",
          "label": "Падение напряжения (В)",
        },
        "voltageDropPct": {
          "help": "Падение как процент от напряжения источника. NEC рекомендует ≤3%.",
          "label": "Падение напряжения (%)",
        },
      },
      "short": "Рассчитайте падение напряжения в электрических кабелях для однофазных цепей по нормам NEC.",
      "title": "Калькулятор падения напряжения",
    },
    "tr": {
      "description": "Bakır ve alüminyum iletkenler için ücretsiz gerilim düşümü hesaplayıcısı. İletken kesitini, tek yön uzunluğu, akımı ve sistem gerilimini girerek gerilim düşümü, yüzde düşüm ve NEC uygunluk durumunu öğrenin.",
      "errors": {
        "invalidGauge": "Kablo kalınlığı pozitif bir sayı olmalıdır.",
      },
      "faq": [
        {
          "a": "Ulusal Elektrik Kodu (NEC), dallanma devrelerinde tam yük altında gerilim düşümünün kaynak geriliminin %3'ünü aşmamasını ve besleme ile dallanma devresi toplamının %5'i geçmemesini tavsiye eder.",
          "q": "NEC'in %3 gerilim düşümü kuralı nedir?",
        },
      ],
      "inputs": {
        "conductorMaterial": {
          "help": "Bakırın özgül direnci alüminyumdan düşüktür.",
          "label": "İletken malzeme",
        },
        "currentA": {
          "help": "Yük akımı (amper).",
          "label": "Akım (A)",
        },
        "lengthM": {
          "help": "Kaynaktan yüke olan mesafe (metre). Toplam kablo uzunluğu bunun iki katıdır.",
          "label": "Tek yön uzunluk (m)",
        },
        "voltage": {
          "help": "Kaynaktaki nominal sistem gerilimi.",
          "label": "Kaynak gerilimi (V)",
        },
        "wireGauge": {
          "help": "AWG numarası (küçük = daha kalın) veya mm² cinsinden kesit.",
          "label": "Kablo kalınlığı",
        },
        "wireGaugeUnit": {
          "help": "AWG (Amerikan Tel Kaliperi) veya mm² kesit alanı.",
          "label": "Kablo kesit birimi",
        },
      },
      "keywords": [
        "gerilim düşümü hesaplayıcı",
        "kablo gerilim düşümü",
        "AWG gerilim düşümü",
        "elektrik kablo hesaplayıcı",
      ],
      "options": {
        "conductorMaterial": {
          "aluminum": "Alüminyum (Al)",
          "copper": "Bakır (Cu)",
        },
        "wireGaugeUnit": {
          "awg": "AWG (Amerikan Tel Kaliperi)",
          "mm2": "mm² (kesit alanı)",
        },
      },
      "outputs": {
        "areaMm2": {
          "help": "İletkenin etkin kesit alanı.",
          "label": "İletken kesiti (mm²)",
