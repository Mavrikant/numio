        "receivingVoltage": {
          "help": "Yükte mevcut gerçek gerilim.",
          "label": "Alınan gerilim (V)",
        },
        "recommendation": {
          "help": "ok = ≤%3, uyarı = %3–5, kritik = >%5.",
          "label": "NEC durumu",
        },
        "voltageDrop": {
          "help": "Her iki iletkendeki toplam gerilim kaybı (gidiş-dönüş).",
          "label": "Gerilim düşümü (V)",
        },
        "voltageDropPct": {
          "help": "Kaynak gerilimine oranla düşüm. NEC ≤%3 önerir.",
          "label": "Gerilim düşümü (%)",
        },
      },
      "short": "NEC kılavuzlarına göre tek fazlı devrelerde elektrik kablolarındaki gerilim düşümünü hesaplayın.",
      "title": "Gerilim Düşümü Hesaplayıcı",
    },
    "zh": {
      "description": "免费铜铝导体电压降计算器。输入导体截面积（AWG或mm²）、单程长度、电流和系统电压，即可获得电压降、百分比降和NEC合规状态。",
      "errors": {
        "invalidGauge": "线径必须为正数。",
      },
      "faq": [
        {
          "a": "美国国家电气法规（NEC）建议分支电路在满载时的电压降不超过电源电压的3%，馈线与分支电路的综合压降不超过5%。",
          "q": "NEC的3%规则是什么？",
        },
      ],
      "inputs": {
        "conductorMaterial": {
          "help": "铜的电阻率低于铝。",
          "label": "导体材料",
        },
        "currentA": {
          "help": "负载电流（安培）。",
          "label": "电流（A）",
        },
        "lengthM": {
          "help": "从电源到负载的距离（米）。总电缆长度为此值的两倍。",
          "label": "单程长度（m）",
        },
        "voltage": {
          "help": "电源处的额定系统电压。",
          "label": "电源电压（V）",
        },
        "wireGauge": {
          "help": "AWG编号（数字越小越粗）或mm²截面积。",
          "label": "线径/截面积",
        },
        "wireGaugeUnit": {
          "help": "AWG（美国线规）或mm²横截面积。",
          "label": "线径单位",
        },
      },
      "keywords": [
        "电压降计算器",
        "电缆电压降",
        "AWG电压降",
        "NEC电压降",
        "导线截面积计算器",
      ],
      "options": {
        "conductorMaterial": {
          "aluminum": "铝（Al）",
          "copper": "铜（Cu）",
        },
        "wireGaugeUnit": {
          "awg": "AWG（美国线规）",
          "mm2": "mm²（截面积）",
        },
      },
      "outputs": {
        "areaMm2": {
          "help": "导体的有效横截面积。",
          "label": "导体面积（mm²）",
        },
        "receivingVoltage": {
          "help": "负载处实际可用电压。",
          "label": "负载端电压（V）",
        },
        "recommendation": {
          "help": "ok = ≤3%，警告 = 3–5%，严重 = >5%。",
          "label": "NEC状态",
        },
        "voltageDrop": {
          "help": "两根导体上的总电压损失（双程路径）。",
          "label": "电压降（V）",
        },
        "voltageDropPct": {
          "help": "相对于电源电压的降落百分比。NEC建议不超过3%。",
          "label": "电压降（%）",
        },
      },
      "short": "根据NEC指南计算单相电路中电缆的电压降。",
      "title": "电压降计算器",
    },
  },
