          "aluminum": "알루미늄(Al)",
          "copper": "구리(Cu)",
        },
        "wireGaugeUnit": {
          "awg": "AWG(미국 전선 규격)",
          "mm2": "mm²(단면적)",
        },
      },
      "outputs": {
        "areaMm2": {
          "help": "도체의 유효 단면적.",
          "label": "도체 단면적(mm²)",
        },
        "receivingVoltage": {
          "help": "부하에서 실제로 사용 가능한 전압.",
          "label": "수전 전압(V)",
        },
        "recommendation": {
          "help": "ok = ≤3%, 경고 = 3–5%, 위험 = >5%.",
