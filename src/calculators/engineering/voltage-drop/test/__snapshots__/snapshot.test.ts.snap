          "label": "편도 길이(m)",
        },
        "voltage": {
          "help": "전원 측 공칭 시스템 전압.",
          "label": "전원 전압(V)",
        },
        "wireGauge": {
          "help": "AWG 번호(작을수록 굵음) 또는 mm² 단면적.",
          "label": "선경 / 단면적",
        },
        "wireGaugeUnit": {
          "help": "AWG(미국 전선 규격) 또는 mm² 단면적.",
          "label": "선경 단위",
        },
      },
      "keywords": [
        "전압 강하 계산기",
        "케이블 전압 강하",
        "AWG 전압 강하",
        "NEC 전압 강하",
        "전선 단면적 계산기",
      ],
      "options": {
