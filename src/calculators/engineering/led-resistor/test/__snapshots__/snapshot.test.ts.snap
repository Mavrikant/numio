          "label": "सटीक रेसिस्टेंस (Ω)",
        },
        "powerDissipatedW": {
          "help": "रेसिस्टर द्वारा उत्पन्न गर्मी: P = (Vसप्लाई - Vफॉरवर्ड×n) × I। इस मान के 2× रेटिंग वाला रेसिस्टर उपयोग करें।",
          "label": "बिजली हानि (W)",
        },
        "resistorColorCode": {
          "help": "मानक E12 रेसिस्टर के लिए 4-बैंड रंग कोड (टॉलरेंस बैंड = गोल्ड ±5%)।",
          "label": "रेसिस्टर रंग कोड",
        },
        "standardResistanceOhm": {
          "help": "ऊपर की ओर गोल किया गया निकटतम E12 मानक मान — LED के लिए सुरक्षित कम करंट प्रदान करता है।",
          "label": "मानक E12 रेसिस्टेंस (Ω)",
        },
      },
      "short": "अपने LED सर्किट के लिए सही करंट-लिमिटिंग रेसिस्टर की गणना करें।",
      "title": "LED रेसिस्टर कैलकुलेटर",
    },
    "it": {
      "description": "Calcolatore di resistenza LED gratuito. Inserisci la tensione di alimentazione, la tensione diretta del LED e la corrente desiderata per trovare il valore esatto e standard E12, la dissipazione di potenza e il codice colore.",
      "errors": {
        "supplyTooLow": "La tensione di alimentazione deve essere maggiore della tensione diretta totale del LED.",
      },
      "faq": [
        {
          "a": "I LED hanno una resistenza interna molto bassa. Senza una resistenza in serie, anche un piccolo aumento di tensione può causare un grande aumento di corrente che distrugge permanentemente il LED.",
          "q": "Perché i LED hanno bisogno di una resistenza limitatrice di corrente?",
        },
        {
          "a": "E12 è un insieme standard di 12 valori di resistenze preferiti per decennio definito dall'EIA. Questi valori sono distribuiti approssimativamente in modo uniforme su una scala logaritmica.",
          "q": "Cos'è la serie di resistenze E12?",
        },
        {
          "a": "Scegli sempre una potenza nominale almeno doppia rispetto alla potenza dissipata calcolata. Se il calcolatore mostra 0,08W, usa una resistenza da 0,25W.",
          "q": "Quale potenza nominale devo scegliere per la resistenza?",
        },
      ],
      "inputs": {
        "forwardCurrentMa": {
          "help": "Corrente di funzionamento target del LED in milliampere. La maggior parte dei LED standard funziona a 20mA.",
          "label": "Corrente desiderata (mA)",
        },
        "forwardVoltage": {
          "help": "Caduta di tensione su un singolo LED in conduzione (tipico: rosso=2,0V, blu/bianco=3,2V).",
          "label": "Tensione diretta del LED (V)",
        },
        "ledCount": {
          "help": "Quanti LED sono collegati in serie sulla stessa resistenza.",
          "label": "Numero di LED in serie",
        },
        "supplyVoltage": {
          "help": "La tensione continua del tuo alimentatore (es. 5V per USB, 12V per circuiti auto).",
          "label": "Tensione di alimentazione (V)",
        },
      },
      "keywords": [
        "calcolatore resistenza LED",
        "resistenza limitatrice di corrente",
        "circuito LED",
        "serie E12",
        "codice colore resistenza",
        "tensione diretta LED",
        "calcolatore elettronico",
      ],
      "outputs": {
        "actualCurrentMa": {
          "help": "Corrente LED reale usando il valore di resistenza E12 standard.",
          "label": "Corrente reale con resistenza standard (mA)",
