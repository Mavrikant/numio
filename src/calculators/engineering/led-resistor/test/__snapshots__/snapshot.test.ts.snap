        "resistorColorCode": {
          "help": "Codice colore a 4 bande per la resistenza E12 standard (banda di tolleranza = oro ±5%).",
          "label": "Codice colore della resistenza",
        },
        "standardResistanceOhm": {
          "help": "Valore standard E12 più vicino arrotondato per eccesso — fornisce una corrente inferiore sicura per il LED.",
          "label": "Resistenza E12 standard (Ω)",
        },
      },
      "short": "Calcola la resistenza limitatrice di corrente corretta per il tuo circuito LED.",
      "title": "Calcolatore resistenza LED",
    },
    "ja": {
      "description": "無料のLED抵抗計算機。電源電圧・LEDの順方向電圧・目標電流を入力するだけで、正確な抵抗値とE12標準値、電力損失、カラーコードが分かります。",
      "errors": {
        "supplyTooLow": "電源電圧はLEDの合計順方向電圧より大きくなければなりません。",
      },
      "faq": [
        {
          "a": "LEDは内部抵抗が非常に低いため、直列抵抗がないと電圧が少し上がるだけで大電流が流れ、LEDが永久に破損します。",
          "q": "LEDに電流制限抵抗が必要なのはなぜですか？",
        },
        {
          "a": "E12はEIAが定義した、1桁あたり12個の優先抵抗値の標準セットです。これらの値は対数スケール上でほぼ等間隔に並んでいます。",
          "q": "E12抵抗シリーズとは何ですか？",
        },
        {
          "a": "計算した電力損失の少なくとも2倍の定格電力を持つ抵抗を選んでください。例えば0.08Wなら0.25Wの抵抗を使います。",
          "q": "抵抗の定格電力はどう選びますか？",
        },
      ],
      "inputs": {
        "forwardCurrentMa": {
          "help": "LEDの動作電流の目標値（ミリアンペア）。一般的なLEDは20mAで動作します。",
          "label": "目標電流（mA）",
        },
        "forwardVoltage": {
          "help": "LEDが導通している際の電圧降下（目安：赤=2.0V、青/白=3.2V）。",
          "label": "LED順方向電圧（V）",
        },
        "ledCount": {
          "help": "同じ抵抗に直列接続されているLEDの数。",
          "label": "直列接続LED数",
        },
        "supplyVoltage": {
          "help": "電源のDC電圧（例：USBは5V、車載回路は12V）。",
          "label": "電源電圧（V）",
        },
      },
      "keywords": [
        "LED抵抗計算機",
        "電流制限抵抗",
        "LED回路",
        "E12抵抗シリーズ",
        "抵抗カラーコード",
        "LED順方向電圧",
        "電子回路計算",
      ],
      "outputs": {
        "actualCurrentMa": {
          "help": "E12標準抵抗値使用時のLED実電流。",
          "label": "標準抵抗使用時の実電流（mA）",
        },
        "exactResistanceOhm": {
          "help": "オームの法則による計算値：R = (V電源 - V順方向×n) / I。",
          "label": "計算抵抗値（Ω）",
        },
        "powerDissipatedW": {
          "help": "抵抗が発生させる熱：P = (V電源 - V順方向×n) × I。この値の2倍以上の定格抵抗を使用してください。",
          "label": "電力損失（W）",
        },
        "resistorColorCode": {
          "help": "E12標準抵抗の4バンドカラーコード（許容差バンド＝金色±5%）。",
          "label": "抵抗カラーコード",
        },
        "standardResistanceOhm": {
          "help": "切り上げた最近接E12標準値——LEDに対して安全な低電流を提供します。",
          "label": "E12標準抵抗値（Ω）",
        },
      },
      "short": "LED回路に必要な電流制限抵抗を計算します。",
      "title": "LED抵抗計算機",
    },
