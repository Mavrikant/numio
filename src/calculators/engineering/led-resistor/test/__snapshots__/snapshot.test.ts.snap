        "exactResistanceOhm": {
          "help": "Valore di resistenza calcolato con la legge di Ohm: R = (Valim - Vdiretta×n) / I.",
          "label": "Resistenza esatta (Ω)",
        },
        "powerDissipatedW": {
          "help": "Calore generato dalla resistenza: P = (Valim - Vdiretta×n) × I. Usa una resistenza con il doppio di questa potenza nominale.",
          "label": "Potenza dissipata (W)",
