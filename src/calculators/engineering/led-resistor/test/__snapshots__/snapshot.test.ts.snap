    },
    "zh": {
      "description": "免费LED电阻计算器。输入电源电压、LED正向电压和所需电流，获取精确值和E12标准电阻值、功耗及色环代码。",
      "errors": {
        "supplyTooLow": "电源电压必须大于LED正向总电压。",
      },
      "faq": [
        {
          "a": "LED的内阻非常低。没有串联电阻，即使电压轻微升高也会引起大电流冲击，永久损坏LED。",
          "q": "为什么LED需要限流电阻？",
        },
        {
          "a": "E12是EIA定义的每十倍频程12个优选电阻值的标准系列，这些值在对数坐标上大致均匀分布。",
          "q": "什么是E12电阻系列？",
        },
        {
          "a": "始终选择额定功率至少为计算功耗两倍的电阻。例如计算器显示0.08W，则使用0.25W电阻。",
          "q": "应选择多大功率的电阻？",
        },
      ],
      "inputs": {
        "forwardCurrentMa": {
          "help": "LED工作电流目标值（毫安）。大多数标准LED工作电流为20mA。",
          "label": "目标电流（mA）",
        },
        "forwardVoltage": {
          "help": "单个LED导通时的电压降（典型值：红色=2.0V，蓝色/白色=3.2V）。",
          "label": "LED正向电压（V）",
        },
        "ledCount": {
          "help": "连接在同一电阻上的串联LED数量。",
          "label": "串联LED数量",
        },
        "supplyVoltage": {
          "help": "电源的直流电压（如USB为5V，汽车电路为12V）。",
          "label": "电源电压（V）",
        },
      },
      "keywords": [
        "LED电阻计算器",
        "限流电阻",
        "LED电路",
        "E12电阻系列",
        "电阻色环",
        "LED正向电压",
        "电子计算器",
      ],
      "outputs": {
        "actualCurrentMa": {
          "help": "使用E12标准电阻值时LED的实际电流。",
          "label": "使用标准电阻的实际电流（mA）",
        },
        "exactResistanceOhm": {
          "help": "根据欧姆定律计算的电阻值：R = (V供电 - V正向×n) / I。",
          "label": "精确电阻值（Ω）",
        },
        "powerDissipatedW": {
          "help": "电阻产生的热量：P = (V供电 - V正向×n) × I。选择额定功率为计算值两倍的电阻。",
          "label": "功率耗散（W）",
        },
        "resistorColorCode": {
          "help": "E12标准电阻的4色环代码（容差色环=金色±5%）。",
          "label": "电阻色环代码",
        },
        "standardResistanceOhm": {
          "help": "向上取整的最近E12标准值——为LED提供较低的安全电流。",
          "label": "E12标准电阻值（Ω）",
        },
      },
      "short": "计算LED电路所需的限流电阻值。",
      "title": "LED限流电阻计算器",
    },
  },
