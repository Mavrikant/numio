    "zh": {
      "description": "免费欧姆定律计算器。输入电压（V）、电流（I）、电阻（R）、功率（P）中的任意两个值，即可利用V=IR和P=VI公式瞬间计算出其余两个。",
      "errors": {
        "nonPositive": "所有值必须大于零。",
        "sameQuantity": "两个已知量必须不同。",
      },
      "faq": [
        {
          "a": "欧姆定律指出，在温度不变的条件下，导体两端的电压与通过它的电流成正比：V = I × R。",
          "q": "什么是欧姆定律？",
        },
        {
          "a": "功率有三种计算方式：P = V × I、P = I² × R 或 P = V² / R。本计算器在已知任意两个量时可求解全部四个量。",
          "q": "如何计算功率？",
        },
      ],
      "inputs": {
        "knownQty1": {
          "help": "选择第一个已知的电气量。",
          "label": "第一个已知量",
        },
        "knownQty2": {
          "help": "选择第二个已知的电气量（必须与第一个不同）。",
          "label": "第二个已知量",
        },
        "value1": {
          "help": "输入第一个已知量的数值。",
          "label": "值 1",
        },
        "value2": {
          "help": "输入第二个已知量的数值。",
          "label": "值 2",
        },
      },
      "keywords": [
        "欧姆定律计算器",
        "电压计算器",
        "电流计算器",
        "电阻计算器",
        "功率计算器",
        "V=IR",
        "电子计算器",
      ],
      "options": {
        "knownQty1": {
          "current": "电流（A）",
          "power": "功率（W）",
          "resistance": "电阻（Ω）",
          "voltage": "电压（V）",
        },
        "knownQty2": {
          "current": "电流（A）",
          "power": "功率（W）",
          "resistance": "电阻（Ω）",
          "voltage": "电压（V）",
        },
      },
      "outputs": {
        "current": {
          "help": "以安培为单位的电荷流量。",
          "label": "电流（I）",
        },
        "power": {
          "help": "以瓦特为单位的能量传输速率。",
          "label": "功率（P）",
        },
        "resistance": {
          "help": "以欧姆为单位的电流阻力。",
