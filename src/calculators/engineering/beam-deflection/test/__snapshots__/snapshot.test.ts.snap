  "icon": Any<String>,
  "inputSchema": ZodObject {
    "decode": [Function],
    "decodeAsync": [Function],
    "def": {
      "checks": [
        $ZodCheck {},
      ],
      "shape": {
        "E": ZodNumber {
          "decode": [Function],
          "decodeAsync": [Function],
          "def": {
            "checks": [
              $ZodCheckGreaterThan {},
            ],
            "type": "number",
          },
          "encode": [Function],
          "encodeAsync": [Function],
          "format": null,
          "isFinite": true,
          "isInt": false,
          "maxValue": Infinity,
          "minValue": 0,
          "parse": [Function],
          "parseAsync": [Function],
          "safeDecode": [Function],
          "safeDecodeAsync": [Function],
          "safeEncode": [Function],
          "safeEncodeAsync": [Function],
          "safeParse": [Function],
          "safeParseAsync": [Function],
          "spa": [Function],
          "toJSONSchema": [Function],
          "type": "number",
        },
        "I": ZodNumber {
          "decode": [Function],
          "decodeAsync": [Function],
          "def": {
