        },
        "pf": {
          "help": "有功功率与视在功率之比（0到1）。功率因数=1表示纯电阻负载。",
          "label": "功率因数",
        },
        "reactivePowerKvar": {
          "help": "在电源和负载之间振荡的功率（储存在电感/电容中）。",
          "label": "无功功率（kVAR）",
