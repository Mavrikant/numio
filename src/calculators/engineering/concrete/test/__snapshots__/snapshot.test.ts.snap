        },
        "height": {
          "help": "기둥 또는 원기둥의 높이(m 또는 ft).",
          "label": "높이",
        },
        "length": {
          "help": "부재의 길이(m 또는 ft).",
          "label": "길이",
        },
        "shape": {
          "help": "콘크리트 부재 유형을 선택하세요.",
          "label": "형상",
        },
        "thickness": {
          "help": "슬래브 두께 또는 기초 깊이(m 또는 ft).",
          "label": "두께 / 깊이",
        },
        "unit": {
          "help": "미터법(미터) 또는 야드파운드법(피트).",
          "label": "단위 시스템",
        },
        "width": {
          "help": "부재의 너비(m 또는 ft).",
          "label": "너비",
        },
      },
      "keywords": [
        "콘크리트 부피 계산기",
        "시멘트 포대 계산",
        "콘크리트 슬래브 계산기",
        "기초 콘크리트 계산",
        "건설 계산기",
      ],
      "options": {
        "shape": {
          "column": "직사각형 기둥",
          "cylinder": "원기둥 / 원형 기둥",
          "footing": "기초(직사각형)",
          "slab": "슬래브",
        },
        "unit": {
          "imperial": "야드파운드법 (ft)",
          "metric": "미터법 (m)",
        },
      },
      "outputs": {
        "bags40kg": {
          "help": "필요한 40kg 시멘트 포대 수 추정치(1:2:3 배합).",
          "label": "40kg 포대 수",
        },
        "bags60lb": {
          "help": "필요한 60lb 시멘트 포대 수 추정치(미국 표준).",
          "label": "60lb 포대 수",
