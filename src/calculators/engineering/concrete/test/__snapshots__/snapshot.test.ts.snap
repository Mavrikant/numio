      "short": "슬래브, 기둥, 원기둥, 기초에 필요한 콘크리트 부피와 시멘트 포대 수를 계산합니다.",
      "title": "콘크리트 부피 계산기",
    },
    "ru": {
      "description": "Бесплатный калькулятор объёма бетона для строительных проектов. Введите размеры плит, колонн, цилиндров или фундаментов и получите объём в м³ и yd³, а также количество мешков цемента.",
      "errors": {
        "missingDimensions": "Введите все необходимые размеры для выбранной формы.",
      },
      "faq": [
        {
          "a": "При смеси 1:2:3 на один кубометр бетона требуется около 8 мешков по 40 кг. Добавьте 5–10% на потери.",
          "q": "Сколько мешков цемента на 1 м³ бетона?",
        },
      ],
      "inputs": {
        "diameter": {
          "help": "Диаметр цилиндрического элемента (м или фут).",
          "label": "Диаметр",
        },
        "height": {
          "help": "Высота колонны или цилиндра (м или фут).",
          "label": "Высота",
        },
        "length": {
          "help": "Длина элемента (м или фут).",
          "label": "Длина",
        },
        "shape": {
          "help": "Выберите тип бетонного элемента.",
          "label": "Форма",
        },
        "thickness": {
          "help": "Толщина плиты или глубина фундамента (м или фут).",
          "label": "Толщина / Глубина",
        },
        "unit": {
          "help": "Метрическая (метры) или имперская (футы).",
          "label": "Система единиц",
        },
        "width": {
          "help": "Ширина элемента (м или фут).",
          "label": "Ширина",
        },
      },
      "keywords": [
        "калькулятор бетона",
        "калькулятор мешков цемента",
        "расчёт плиты перекрытия",
        "расчёт фундамента",
        "объём бетона",
      ],
      "options": {
        "shape": {
          "column": "Прямоугольная колонна",
          "cylinder": "Цилиндр / Круглая колонна",
          "footing": "Фундамент (прямоугольный)",
          "slab": "Плита",
        },
        "unit": {
          "imperial": "Имперская (фут)",
          "metric": "Метрическая (м)",
        },
      },
      "outputs": {
        "bags40kg": {
          "help": "Расчётное количество мешков цемента по 40 кг (смесь 1:2:3).",
          "label": "Мешки 40 кг",
        },
        "bags60lb": {
          "help": "Расчётное количество мешков по 60 фунтов (стандарт США).",
          "label": "Мешки 60 фунтов",
        },
        "volumeM3": {
          "help": "Объём бетона в кубических метрах.",
          "label": "Объём (м³)",
        },
        "volumeYd3": {
          "help": "Объём бетона в кубических ярдах.",
          "label": "Объём (yd³)",
        },
      },
      "short": "Рассчитайте объём бетона и количество мешков цемента для плит, колонн, цилиндров и фундаментов.",
      "title": "Калькулятор объёма бетона",
    },
    "tr": {
      "description": "İnşaat projeleri için ücretsiz beton hacmi hesaplayıcısı. Döşeme, kolon, silindir veya temel boyutlarını girerek beton hacmini m³ ve yd³ cinsinden ve gereken çimento torbası sayısını öğrenin.",
      "errors": {
        "missingDimensions": "Seçili şekil için gerekli tüm boyutları girin.",
      },
      "faq": [
        {
          "a": "Standart 1:2:3 karışım (çimento:kum:agrega) için yaklaşık 8 adet 40 kg çimento torbası gerekmektedir. Fire payı için %5–10 ekleyin.",
          "q": "1 m³ beton için kaç çimento torbası gerekir?",
        },
        {
          "a": "Küçük dökümler için en az %5, büyük veya karmaşık dökümler için %10'a kadar ek beton ekleyin. Bu; dökülme, düzensiz zemin ve kalıp düzensizliklerini karşılar.",
          "q": "Neden ekstra beton eklemelisiniz?",
        },
      ],
      "inputs": {
        "diameter": {
          "help": "Silindirik elemanın çapı (m veya ft).",
          "label": "Çap",
        },
        "height": {
          "help": "Kolon veya silindirin yüksekliği (m veya ft).",
          "label": "Yükseklik",
        },
        "length": {
          "help": "Elemanın uzunluğu (m veya ft).",
          "label": "Uzunluk",
        },
        "shape": {
          "help": "Beton eleman türünü seçin.",
          "label": "Şekil",
        },
        "thickness": {
          "help": "Döşeme kalınlığı veya temel derinliği (m veya ft).",
          "label": "Kalınlık / Derinlik",
        },
        "unit": {
          "help": "Metrik (metre) veya İngiliz birimi (fit).",
          "label": "Birim sistemi",
        },
        "width": {
          "help": "Elemanın genişliği (m veya ft).",
          "label": "Genişlik",
        },
      },
      "keywords": [
        "beton hacmi hesaplayıcı",
        "çimento torbası hesaplama",
        "beton döşeme hesaplayıcı",
        "temel beton hesabı",
        "kolon beton hesabı",
        "inşaat hesaplayıcı",
        "beton tahmini",
      ],
      "options": {
        "shape": {
          "column": "Dikdörtgen Kolon",
          "cylinder": "Silindir / Yuvarlak Kolon",
          "footing": "Temel (Dikdörtgen)",
          "slab": "Döşeme",
        },
        "unit": {
          "imperial": "İngiliz birimi (ft)",
          "metric": "Metrik (m)",
        },
      },
      "outputs": {
        "bags40kg": {
          "help": "Gereken 40 kg çimento torbası sayısı (1:2:3 karışım).",
          "label": "40 kg Torba",
        },
        "bags60lb": {
          "help": "Gereken 60 lb çimento torbası sayısı (ABD standardı).",
          "label": "60 lb Torba",
        },
        "volumeM3": {
          "help": "Küp metre cinsinden beton hacmi.",
          "label": "Hacim (m³)",
        },
        "volumeYd3": {
          "help": "Küp yarda cinsinden beton hacmi.",
          "label": "Hacim (yd³)",
        },
      },
      "short": "Döşeme, kolon, silindir ve temel için beton hacmi ve çimento torbası sayısını hesaplayın.",
      "title": "Beton Hacmi Hesaplayıcı",
    },
    "zh": {
      "description": "免费混凝土体积计算器，适用于建筑工程项目。输入板、柱、圆柱体或基础的尺寸，即可获得混凝土体积（m³和yd³）及所需水泥袋数。",
      "errors": {
        "missingDimensions": "请提供所选形状所需的所有尺寸。",
      },
      "faq": [
        {
          "a": "对于标准1:2:3配合比，每立方米混凝土约需8袋40千克水泥。额外增加5–10%以备损耗。",
          "q": "每立方米混凝土需要多少袋水泥？",
        },
      ],
      "inputs": {
        "diameter": {
          "help": "圆柱形构件的直径（m或ft）。",
          "label": "直径",
        },
        "height": {
          "help": "柱或圆柱体的高度（m或ft）。",
          "label": "高度",
        },
        "length": {
          "help": "构件长度（m或ft）。",
          "label": "长度",
        },
        "shape": {
          "help": "选择混凝土构件类型。",
          "label": "形状",
        },
        "thickness": {
          "help": "板的厚度或基础的深度（m或ft）。",
          "label": "厚度/深度",
        },
        "unit": {
          "help": "公制（米）或英制（英尺）。",
          "label": "单位制",
        },
        "width": {
          "help": "构件宽度（m或ft）。",
          "label": "宽度",
        },
      },
      "keywords": [
        "混凝土体积计算器",
        "水泥袋数计算",
        "混凝土板计算",
        "基础混凝土计算",
        "建筑计算器",
      ],
      "options": {
        "shape": {
          "column": "矩形柱",
          "cylinder": "圆柱体/圆柱",
          "footing": "基础（矩形）",
          "slab": "板",
        },
        "unit": {
          "imperial": "英制（ft）",
          "metric": "公制（m）",
        },
      },
      "outputs": {
        "bags40kg": {
          "help": "所需40千克水泥袋的估算数量（1:2:3配合比）。",
          "label": "40千克袋数",
        },
        "bags60lb": {
          "help": "所需60磅水泥袋的估算数量（美国标准）。",
          "label": "60磅袋数",
        },
        "volumeM3": {
          "help": "混凝土体积，以立方米为单位。",
          "label": "体积（m³）",
        },
        "volumeYd3": {
          "help": "混凝土体积，以立方码为单位。",
          "label": "体积（yd³）",
        },
      },
      "short": "计算板、柱、圆柱体和基础所需的混凝土体积及水泥袋数。",
      "title": "混凝土体积计算器",
    },
  },
