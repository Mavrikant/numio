      "short": "Birikim hedefinize kaç ayda ulaşacağınızı öğrenin.",
      "title": "Tasarruf Hedefi Hesaplayıcı",
    },
    "zh": {
      "description": "免费储蓄目标计算器。输入目标金额、当前存款、每月存入金额和预期年收益率，即可查看何时实现储蓄目标。",
      "errors": {
        "contributionTooLow": "每月存入金额必须大于零。",
        "goalNotReachable": "在这些条件下，无法在100年内实现目标。",
        "targetTooLow": "目标金额必须大于零。",
      },
      "faq": [
        {
          "a": "高收益储蓄账户可能提供3–5%的年利率。多元化股票指数基金历史上通货膨胀前年均回报约7–10%。短期目标使用4–6%，长期投资使用6–8%。",
          "q": "应该使用多少年收益率？",
        },
        {
          "a": "不考虑。请将预期通胀率（约2–3%）从名义利率中减去，以获得实际回报率。",
          "q": "计算器是否考虑通货膨胀？",
        },
      ],
      "inputs": {
        "annualReturn": {
          "help": "预期年利率或投资回报率，默认为5%。",
          "label": "年收益率（%）",
        },
        "currentSavings": {
          "help": "您已为该目标存入的金额。",
          "label": "当前存款",
        },
        "monthlyContribution": {
          "help": "每月固定存入的金额。",
          "label": "每月存入金额",
        },
        "targetAmount": {
          "help": "您希望储蓄的总金额。",
          "label": "目标金额",
        },
      },
      "keywords": [
        "储蓄目标计算器",
        "需要多久存钱",
        "每月储蓄",
        "复利计算",
        "储蓄计划",
        "理财计算器",
        "存钱计划",
      ],
      "outputs": {
        "monthsToGoal": {
          "help": "达到储蓄目标需要的月数。",
          "label": "达成目标所需月数",
        },
        "totalContributions": {
          "help": "初始存款加上所有每月存款的总和。",
          "label": "总存入金额",
        },
        "totalInterest": {
          "help": "在存款基础上通过复利获得的增长。",
          "label": "获得的利息",
        },
        "yearsToGoal": {
          "help": "以年为单位的相同时间段。",
          "label": "达成目标所需年数",
        },
      },
      "short": "计算实现储蓄目标需要多少个月。",
      "title": "储蓄目标计算器",
    },
