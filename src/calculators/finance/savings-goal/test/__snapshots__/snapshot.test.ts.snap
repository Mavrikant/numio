  "meta": {
    "compareEnabled": true,
    "disclaimer": "Results are estimates based on a constant annual return. Actual investment returns vary and are not guaranteed.",
    "formulaLatex": "\\text{balance} = \\text{currentSavings} \\times (1+r)^n + \\text{PMT} \\times \\frac{(1+r)^n - 1}{r}",
