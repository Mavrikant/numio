        "monthlyContribution": {
          "help": "Her ay ekleyeceğiniz sabit tutar.",
          "label": "Aylık Katkı",
        },
        "targetAmount": {
          "help": "Biriktirmek istediğiniz toplam tutar.",
          "label": "Hedef Tutar",
        },
      },
      "keywords": [
        "tasarruf hedefi hesaplayıcı",
