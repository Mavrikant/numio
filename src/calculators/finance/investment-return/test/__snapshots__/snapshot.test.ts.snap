          "help": "Прогнозируемая или фактическая итоговая стоимость.",
          "label": "Конечная стоимость",
        },
        "roi": {
          "help": "Общая доходность как процент от начальной суммы.",
          "label": "ROI (%)",
        },
        "totalGain": {
          "help": "Конечная стоимость минус начальные инвестиции.",
          "label": "Общий доход",
