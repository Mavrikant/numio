        "finalValue": {
          "help": "Текущая или итоговая стоимость инвестиции. Оставьте пустым, если вводите годовую доходность.",
          "label": "Конечная стоимость",
        },
        "initialInvestment": {
          "help": "Сумма, вложенная в начале.",
          "label": "Начальные инвестиции",
        },
        "years": {
          "help": "Количество лет, на которые рассчитана инвестиция.",
          "label": "Срок инвестиций (лет)",
        },
      },
      "keywords": [
