        },
        "initialInvestment": {
          "help": "开始时投入的金额。",
          "label": "初始投资",
        },
        "years": {
          "help": "投资持有的年数。",
          "label": "投资期限（年）",
        },
      },
      "keywords": [
        "ROI计算器",
        "CAGR计算器",
        "投资回报率",
        "复合年增长率",
        "投资收益",
        "收益率计算器",
        "年化回报率",
      ],
      "outputs": {
        "cagr": {
          "help": "复合年增长率——产生相同最终价值的稳定年增长率。",
          "label": "CAGR（%）",
        },
        "finalValue": {
          "help": "预测或实际的期末价值。",
          "label": "最终价值",
        },
        "roi": {
          "help": "相对于初始金额的总投资回报率。",
          "label": "ROI（%）",
        },
        "totalGain": {
          "help": "最终价值减去初始投资。",
          "label": "总收益",
