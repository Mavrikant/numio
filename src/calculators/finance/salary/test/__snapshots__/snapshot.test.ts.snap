        "給与計算ツール",
      ],
      "options": {
        "filingStatus": {
          "head": "世帯主",
          "married": "既婚（共同申告）",
          "single": "独身",
        },
      },
      "outputs": {
        "effectiveTaxRate": {
          "help": "総税額の税引き前年収に対する割合。",
          "label": "実効税率",
        },
        "federalIncomeTax": {
          "help": "2024年の米国連邦累進税率に基づく税額。",
          "label": "連邦所得税",
        },
        "medicareTax": {
          "help": "全賃金に1.45%；200,000ドル超の部分に追加0.9%。",
          "label": "メディケア税",
        },
        "netAnnual": {
          "help": "すべての税金・控除後の年収。",
          "label": "年間手取り額",
        },
        "netMonthly": {
          "help": "年間手取り額を12で割った額。",
          "label": "月間手取り額",
        },
        "socialSecurityTax": {
          "help": "168,600ドルまでの賃金に6.2%（2024年の課税賃金上限）。",
          "label": "社会保障税",
        },
        "stateIncomeTax": {
          "help": "入力した一律税率で計算。",
          "label": "州所得税",
        },
        "totalTax": {
          "help": "差し引かれるすべての税金の合計。",
          "label": "税額合計",
        },
      },
      "short": "手取り計算",
      "title": "給与・手取り計算ツール",
    },
    "ko": {
      "description": "미국 연방 소득세, 사회보장세, 메디케어세, 주 소득세를 공제한 후의 실수령액을 추정합니다.",
      "inputs": {
        "annualSalary": {
          "help": "세금 및 공제 전 총 연봉.",
          "label": "연봉 (세전)",
        },
        "filingStatus": {
          "help": "연방세 신고 상태. '세대주'는 미혼으로 부양가족 생활비의 절반 이상을 부담하는 경우에 해당합니다.",
          "label": "세금 신고 상태",
        },
        "preTaxDeductions": {
          "help": "401(k), 건강보험료, HSA 등 세금 혜택 계좌에 대한 연간 기여금으로, 과세 소득을 줄입니다.",
          "label": "세전 공제액",
        },
        "stateIncomeTaxRate": {
          "help": "거주하는 주의 단일 소득세율(퍼센트). 주 소득세가 없는 주에 거주하면 0을 입력하세요.",
          "label": "주 소득세율",
        },
      },
      "keywords": [
        "급여",
        "실수령액",
        "소득세",
        "연방세",
        "FICA",
        "급여 계산기",
      ],
      "options": {
        "filingStatus": {
          "head": "세대주",
          "married": "기혼 (공동 신고)",
          "single": "미혼",
        },
      },
      "outputs": {
        "effectiveTaxRate": {
          "help": "총 세금의 세전 연봉 대비 비율.",
          "label": "실효 세율",
        },
        "federalIncomeTax": {
          "help": "2024년 미국 연방 누진 세율 기준 세액.",
          "label": "연방 소득세",
        },
        "medicareTax": {
          "help": "모든 급여에 1.45%; $200,000 초과분에 추가 0.9%.",
          "label": "메디케어세",
        },
        "netAnnual": {
          "help": "모든 세금 및 공제 후 연봉.",
          "label": "연간 실수령액",
        },
        "netMonthly": {
          "help": "연간 실수령액을 12로 나눈 금액.",
          "label": "월 실수령액",
        },
        "socialSecurityTax": {
          "help": "$168,600까지의 급여에 6.2% (2024년 과세 임금 기준).",
          "label": "사회보장세",
        },
        "stateIncomeTax": {
          "help": "입력한 고정 세율로 계산.",
          "label": "주 소득세",
        },
        "totalTax": {
          "help": "공제되는 모든 세금의 합계.",
          "label": "총 세금",
        },
      },
      "short": "실수령액",
      "title": "급여 및 실수령액 계산기",
    },
    "ru": {
      "description": "Рассчитайте свою чистую зарплату в США после федерального налога на доходы, взносов в Социальное обеспечение, Medicare и налога штата.",
      "inputs": {
        "annualSalary": {
          "help": "Ваша годовая зарплата до налогов и удержаний.",
          "label": "Годовая зарплата (брутто)",
        },
        "filingStatus": {
          "help": "Ваш статус подачи федеральной налоговой декларации. «Глава домохозяйства» применяется, если вы не состоите в браке и оплачиваете более половины расходов на содержание соответствующего лица.",
          "label": "Налоговый статус",
        },
        "preTaxDeductions": {
          "help": "Годовые взносы на счета с налоговыми льготами, такими как 401(k), страховые взносы на здоровье или HSA, уменьшающие налогооблагаемый доход.",
          "label": "Вычеты до налогов",
        },
        "stateIncomeTaxRate": {
          "help": "Фиксированная ставка подоходного налога вашего штата в процентах. Введите 0, если ваш штат не взимает подоходный налог.",
          "label": "Ставка налога штата",
        },
      },
      "keywords": [
        "зарплата",
        "чистая зарплата",
        "налог",
        "федеральный налог",
        "FICA",
        "калькулятор зарплаты",
      ],
      "options": {
        "filingStatus": {
          "head": "Глава домохозяйства",
          "married": "Женат/Замужем (совместная декларация)",
          "single": "Холостой/Незамужняя",
        },
      },
      "outputs": {
        "effectiveTaxRate": {
          "help": "Общий налог как процент от брутто-зарплаты.",
          "label": "Эффективная налоговая ставка",
        },
        "federalIncomeTax": {
          "help": "Налог по прогрессивным ставкам США 2024 года.",
          "label": "Федеральный подоходный налог",
        },
        "medicareTax": {
          "help": "1,45% со всей зарплаты; дополнительно 0,9% свыше $200 000.",
          "label": "Налог Medicare",
        },
        "netAnnual": {
          "help": "Ваша зарплата после всех налогов и удержаний.",
          "label": "Чистая годовая зарплата",
        },
        "netMonthly": {
          "help": "Годовая чистая зарплата, делённая на 12.",
          "label": "Чистая ежемесячная зарплата",
        },
        "socialSecurityTax": {
          "help": "6,2% с зарплаты до $168 600 (база 2024 года).",
          "label": "Взносы в Социальное обеспечение",
        },
        "stateIncomeTax": {
          "help": "Рассчитан по введённой вами ставке.",
          "label": "Налог штата",
        },
        "totalTax": {
          "help": "Сумма всех удержанных налогов.",
          "label": "Итого налогов",
        },
      },
      "short": "Чистая зарплата",
      "title": "Калькулятор чистой зарплаты",
    },
    "tr": {
      "description": "Federal gelir vergisi, Sosyal Güvenlik, Medicare ve eyalet gelir vergisi düşüldükten sonra ABD'de elde kalacak gelirinizi tahmin edin.",
      "inputs": {
        "annualSalary": {
          "help": "Vergi ve kesintiler öncesi brüt yıllık maaşınız.",
          "label": "Yıllık Maaş",
        },
        "filingStatus": {
          "help": "Federal vergi beyanname durumunuz. 'Hane Reisi' durumu, bekar olup bir bakmakla yükümlü olduğunuz kişinin giderlerinin yarısından fazlasını karşılıyorsanız geçerlidir.",
          "label": "Vergi Beyanname Durumu",
        },
        "preTaxDeductions": {
          "help": "401(k), sağlık sigortası primleri veya HSA gibi vergi avantajlı hesaplara yıllık katkılar; vergilendirilebilir gelirinizi azaltır.",
          "label": "Vergi Öncesi Kesintiler",
        },
        "stateIncomeTaxRate": {
          "help": "Eyaletinizin düz oranlı gelir vergisi yüzdesi. Gelir vergisi olmayan bir eyalette yaşıyorsanız 0 girin.",
          "label": "Eyalet Gelir Vergisi Oranı",
        },
      },
      "keywords": [
        "maaş",
        "net maaş",
        "vergi",
        "federal gelir vergisi",
        "FICA",
        "maaş hesaplayıcı",
      ],
      "options": {
        "filingStatus": {
          "head": "Hane Reisi",
          "married": "Evli (Birlikte Beyanname)",
          "single": "Bekar",
        },
      },
      "outputs": {
        "effectiveTaxRate": {
          "help": "Brüt maaşın yüzdesi olarak toplam vergi.",
          "label": "Efektif Vergi Oranı",
        },
        "federalIncomeTax": {
          "help": "2024 ABD federal kademeli vergi dilimleri.",
          "label": "Federal Gelir Vergisi",
        },
        "medicareTax": {
          "help": "Tüm ücretlerde %1,45; 200.000 doların üzerinde ek %0,9.",
          "label": "Medicare Vergisi",
        },
        "netAnnual": {
          "help": "Tüm vergi ve kesintilerden sonraki maaşınız.",
          "label": "Yıllık Net Gelir",
        },
        "netMonthly": {
          "help": "Yıllık net gelirinizin 12'ye bölümü.",
          "label": "Aylık Net Gelir",
        },
        "socialSecurityTax": {
          "help": "168.600 dolara kadar %6,2.",
          "label": "Sosyal Güvenlik Vergisi",
        },
        "stateIncomeTax": {
          "help": "Girdiğiniz düz oran üzerinden hesaplanır.",
          "label": "Eyalet Gelir Vergisi",
        },
        "totalTax": {
          "help": "Kesilen tüm vergilerin toplamı.",
          "label": "Toplam Vergi",
        },
      },
      "short": "Net Maaş",
      "title": "Maaş ve Elde Kalacak Gelir Hesaplayıcısı",
    },
    "zh": {
      "description": "估算扣除美国联邦所得税、社会保障税、医疗保险税和州所得税后的税后收入。",
      "inputs": {
        "annualSalary": {
          "help": "扣税及其他扣款前的年薪总额。",
          "label": "年薪（税前）",
        },
        "filingStatus": {
          "help": "您的联邦税务申报身份。如果您未婚且支付了供养合格人员超过一半的费用，则适用「户主」身份。",
          "label": "报税身份",
        },
        "preTaxDeductions": {
          "help": "每年向401(k)、健康保险费或HSA等税收优惠账户缴纳的金额，可减少应税收入。",
          "label": "税前扣除额",
        },
        "stateIncomeTaxRate": {
          "help": "您所在州的单一税率（百分比）。如您所在州无州所得税，请填写0。",
          "label": "州所得税率",
        },
      },
      "keywords": [
        "薪资",
        "税后收入",
        "所得税",
        "联邦税",
        "FICA",
        "工资计算器",
      ],
      "options": {
        "filingStatus": {
          "head": "户主",
          "married": "已婚联合申报",
          "single": "单身",
        },
      },
      "outputs": {
        "effectiveTaxRate": {
          "help": "税款总额占税前薪资的百分比。",
          "label": "实际税率",
        },
        "federalIncomeTax": {
          "help": "依据2024年美国联邦累进税率计算。",
          "label": "联邦所得税",
        },
        "medicareTax": {
          "help": "全部工资征收1.45%；超过$200,000部分额外征收0.9%。",
          "label": "医疗保险税",
        },
        "netAnnual": {
          "help": "扣除所有税款和扣款后的年薪。",
          "label": "年税后收入",
        },
        "netMonthly": {
          "help": "年税后收入除以12。",
          "label": "月税后收入",
        },
        "socialSecurityTax": {
          "help": "对$168,600以下工资征收6.2%（2024年工资基数）。",
          "label": "社会保障税",
        },
        "stateIncomeTax": {
          "help": "按您输入的固定税率计算。",
          "label": "州所得税",
        },
        "totalTax": {
          "help": "所有代扣税款之和。",
          "label": "税款合计",
        },
      },
      "short": "税后收入",
      "title": "薪资税后收入计算器",
    },
  },
