        },
        "loanAmount": {
          "help": "부동산의 총 구입 가격.",
          "label": "주택 가격",
        },
        "termYears": {
          "help": "대출을 상환하는 데 걸리는 연수.",
          "label": "대출 기간 (년)",
        },
      },
      "keywords": [
