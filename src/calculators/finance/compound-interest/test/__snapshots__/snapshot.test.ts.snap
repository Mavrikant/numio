      "title": "Bileşik Faiz Hesaplayıcı",
    },
    "zh": {
      "description": "免费复利计算器。输入初始本金、年利率、复利频率和每月投入金额，即可查看未来价值及逐年增长明细。",
      "errors": {
        "contributionRange": "每月投入必须在 0 至 100,000 之间。",
        "principalRange": "初始投资必须在 0 至 10,000,000 之间。",
        "rateRange": "年利率必须在 0% 至 50% 之间。",
        "yearsRange": "投资期限必须在 1 至 50 年之间。",
      },
      "faq": [
        {
          "a": "复利是在初始本金和已累积利息的基础上计算的利息。与单利不同，复利会随着时间的推移产生指数级增长。",
          "q": "什么是复利？",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "预期年回报率或利率。",
          "label": "年利率 (%)",
        },
        "compoundFrequency": {
          "help": "利息计算并计入本金的频率。",
          "label": "复利频率",
        },
        "monthlyContribution": {
          "help": "每月额外投入的金额。如无则填 0。",
          "label": "每月投入",
        },
        "principal": {
          "help": "今天投入的金额。",
          "label": "初始投资",
        },
        "years": {
          "help": "资金投资的年数。",
          "label": "投资期限（年）",
        },
      },
      "keywords": [
        "复利计算器",
        "投资增长计算器",
        "储蓄计算器",
        "未来价值计算",
        "复合增长",
        "利息计算器",
        "投资回报计算",
      ],
      "options": {
        "compoundFrequency": {
          "annually": "每年（1次/年）",
          "daily": "每日（365次/年）",
          "monthly": "每月（12次/年）",
          "quarterly": "每季度（4次/年）",
        },
      },
      "outputs": {
        "futureValue": {
          "help": "期末账户的总价值。",
          "label": "未来价值",
        },
        "totalContributions": {
          "help": "初始投资加上所有每月投入的总和。",
          "label": "总投入",
        },
        "totalInterest": {
          "help": "复利产生的增长部分。",
          "label": "总利息收益",
        },
        "yearlyBreakdown": {
          "help": "每年的余额、累计投入和利息收益。",
          "label": "逐年明细",
        },
      },
      "short": "计算您的储蓄通过复利和定期投入随时间增长的情况。",
      "title": "复利计算器",
    },
  },
