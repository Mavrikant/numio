      },
      "short": "Calcola come cresce il tuo risparmio con l'interesse composto e contributi mensili.",
      "title": "Calcolatore Interesse Composto",
    },
    "ja": {
      "description": "無料の複利計算機です。初期投資額、年利、複利頻度、毎月の積立額を入力して、将来の資産価値と年次成長を確認できます。",
      "errors": {
        "contributionRange": "毎月の積立額は 0 ～ 100,000 の範囲で入力してください。",
        "principalRange": "初期投資額は 0 ～ 10,000,000 の範囲で入力してください。",
        "rateRange": "年利は 0% ～ 50% の範囲で入力してください。",
        "yearsRange": "運用期間は 1 ～ 50 年の範囲で入力してください。",
      },
      "faq": [
        {
          "a": "複利とは、元本だけでなく過去の利息にも利息が付く仕組みです。単利と異なり、複利は時間が経つにつれて指数関数的な成長をもたらします。",
          "q": "複利とは何ですか？",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "期待する年間利回りまたは金利。",
          "label": "年利 (%)",
        },
        "compoundFrequency": {
          "help": "利息が計算されて残高に加算される頻度。",
          "label": "複利頻度",
        },
        "monthlyContribution": {
          "help": "毎月追加で積み立てる金額。なければ0を入力。",
          "label": "毎月の積立額",
        },
        "principal": {
          "help": "現在投資する金額。",
          "label": "初期投資額",
        },
        "years": {
          "help": "資金を運用する年数。",
          "label": "運用期間（年）",
        },
      },
      "keywords": [
        "複利計算機",
        "投資成長計算",
        "貯蓄計算機",
        "将来価値",
        "複利成長",
        "利息計算",
        "投資収益計算",
      ],
      "options": {
        "compoundFrequency": {
          "annually": "年1回",
          "daily": "年365回（毎日）",
          "monthly": "年12回（毎月）",
          "quarterly": "年4回（四半期）",
        },
      },
      "outputs": {
        "futureValue": {
          "help": "期間終了時の口座の総額。",
          "label": "将来価値",
        },
        "totalContributions": {
          "help": "初期投資額と全積立額の合計。",
          "label": "総投資額",
        },
        "totalInterest": {
          "help": "複利によって生まれた増加分。",
          "label": "利息合計",
        },
        "yearlyBreakdown": {
          "help": "各年の残高・累計投資額・獲得利息。",
          "label": "年次内訳",
        },
      },
      "short": "複利と定期積立によって資産がどのように成長するかを計算します。",
      "title": "複利計算機",
    },
    "ko": {
      "description": "무료 복리 계산기입니다. 초기 투자금, 연이율, 복리 빈도, 월 적립액을 입력하면 미래 가치와 연도별 성장 내역을 확인할 수 있습니다.",
      "errors": {
        "contributionRange": "월 적립금은 0 ~ 100,000 사이여야 합니다.",
        "principalRange": "초기 투자금은 0 ~ 10,000,000 사이여야 합니다.",
        "rateRange": "연이율은 0% ~ 50% 사이여야 합니다.",
        "yearsRange": "투자 기간은 1 ~ 50년 사이여야 합니다.",
      },
      "faq": [
        {
          "a": "복리는 초기 원금뿐만 아니라 이전 기간에 누적된 이자에도 이자가 붙는 방식입니다. 단리와 달리 복리는 시간이 지남에 따라 지수적 성장을 가져옵니다.",
          "q": "복리란 무엇인가요?",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "예상 연간 수익률 또는 이자율.",
          "label": "연이율 (%)",
        },
        "compoundFrequency": {
          "help": "이자가 계산되어 잔액에 추가되는 빈도.",
          "label": "복리 빈도",
        },
        "monthlyContribution": {
          "help": "매월 추가 투자하는 금액. 없으면 0을 입력하세요.",
          "label": "월 적립금",
        },
        "principal": {
          "help": "오늘 투자하는 금액.",
          "label": "초기 투자금",
        },
        "years": {
          "help": "자금을 투자하는 연수.",
          "label": "투자 기간 (년)",
        },
      },
      "keywords": [
        "복리 계산기",
        "투자 성장 계산기",
        "저축 계산기",
        "미래 가치 계산",
        "복합 성장",
        "이자 계산기",
        "투자 수익 계산",
      ],
      "options": {
        "compoundFrequency": {
          "annually": "연간 (1회/년)",
          "daily": "일별 (365회/년)",
          "monthly": "월별 (12회/년)",
          "quarterly": "분기별 (4회/년)",
        },
      },
      "outputs": {
        "futureValue": {
          "help": "기간 말 계좌의 총 가치.",
          "label": "미래 가치",
        },
        "totalContributions": {
          "help": "초기 투자금과 모든 월 적립금의 합계.",
          "label": "총 투자금",
        },
        "totalInterest": {
          "help": "복리로 발생한 성장 금액.",
          "label": "총 이자 수익",
        },
        "yearlyBreakdown": {
          "help": "연도별 잔액, 누적 투자금 및 이자 수익.",
          "label": "연도별 내역",
        },
      },
      "short": "복리와 정기 적립금으로 저축이 시간에 따라 얼마나 성장하는지 계산하세요.",
      "title": "복리 계산기",
    },
    "ru": {
      "description": "Бесплатный калькулятор сложных процентов. Введите начальный капитал, годовую ставку, частоту начисления и ежемесячные взносы — получите будущую стоимость.",
      "errors": {
        "contributionRange": "Ежемесячный взнос должен быть от 0 до 100 000.",
        "principalRange": "Начальный капитал должен быть от 0 до 10 000 000.",
        "rateRange": "Годовая ставка должна быть от 0 % до 50 %.",
        "yearsRange": "Срок должен быть от 1 до 50 лет.",
      },
      "faq": [
        {
          "a": "Сложные проценты начисляются как на начальный капитал, так и на уже накопленные проценты. В отличие от простых процентов, они обеспечивают экспоненциальный рост с течением времени.",
          "q": "Что такое сложные проценты?",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "Ожидаемая годовая доходность или процентная ставка.",
          "label": "Годовая ставка (%)",
        },
        "compoundFrequency": {
          "help": "Как часто проценты начисляются и добавляются к капиталу.",
          "label": "Частота начисления",
        },
        "monthlyContribution": {
          "help": "Дополнительная сумма, вносимая каждый месяц. Введите 0, если взносов нет.",
          "label": "Ежемесячный взнос",
        },
        "principal": {
          "help": "Сумма, вкладываемая сегодня.",
          "label": "Начальный капитал",
        },
        "years": {
          "help": "Как долго деньги находятся в инвестиции.",
          "label": "Срок (лет)",
        },
      },
      "keywords": [
        "калькулятор сложных процентов",
        "калькулятор инвестиций",
        "калькулятор накоплений",
        "будущая стоимость",
        "сложный рост",
        "расчёт процентов",
        "доходность инвестиций",
      ],
      "options": {
        "compoundFrequency": {
          "annually": "Ежегодно (1 раз/год)",
          "daily": "Ежедневно (365 раз/год)",
          "monthly": "Ежемесячно (12 раз/год)",
          "quarterly": "Ежеквартально (4 раза/год)",
        },
      },
      "outputs": {
        "futureValue": {
          "help": "Общая стоимость счёта в конце периода.",
          "label": "Будущая стоимость",
        },
        "totalContributions": {
          "help": "Начальный капитал плюс все ежемесячные взносы.",
          "label": "Итого вложено",
        },
        "totalInterest": {
          "help": "Прирост капитала за счёт сложных процентов.",
          "label": "Заработано процентов",
        },
        "yearlyBreakdown": {
          "help": "Годовой баланс, накопленные взносы и проценты за каждый год.",
          "label": "Разбивка по годам",
        },
      },
      "short": "Рассчитайте, как растут ваши сбережения за счёт сложных процентов и регулярных взносов.",
      "title": "Калькулятор сложных процентов",
    },
    "tr": {
      "description": "Ücretsiz bileşik faiz hesaplayıcı. Anapara, yıllık getiri, bileşikleşme sıklığı ve aylık katkıları girerek gelecekteki değerinizi ve yıllık büyümeyi görün.",
      "errors": {
        "contributionRange": "Aylık katkı 0 ile 100.000 arasında olmalıdır.",
        "principalRange": "Başlangıç yatırımı 0 ile 10.000.000 arasında olmalıdır.",
        "rateRange": "Yıllık oran %0 ile %50 arasında olmalıdır.",
        "yearsRange": "Süre 1 ile 50 yıl arasında olmalıdır.",
      },
      "faq": [
        {
          "a": "Bileşik faiz, hem başlangıç anaparası hem de önceki dönemlerden birikmiş faiz üzerinden hesaplanan faizdir. Basit faizden farklı olarak, bileşik faiz zaman içinde üstel büyüme sağlar.",
          "q": "Bileşik faiz nedir?",
        },
        {
          "a": "72 sayısını yıllık faiz oranına bölerek yatırımın değerini ikiye katlaması için gereken yaklaşık süreyi bulabilirsiniz. %8 yıllık getiri ile para yaklaşık 9 yılda iki katına çıkar.",
          "q": "72 kuralı nedir?",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "Beklenen yıllık getiri veya faiz oranı.",
          "label": "Yıllık Faiz Oranı (%)",
        },
        "compoundFrequency": {
          "help": "Faizin ne sıklıkla hesaplanıp bakiyeye eklendiği.",
          "label": "Bileşikleşme Sıklığı",
        },
        "monthlyContribution": {
          "help": "Her ay eklenen ek tutar. Yoksa 0 girin.",
          "label": "Aylık Katkı",
        },
        "principal": {
          "help": "Bugün yatırdığınız tutar.",
          "label": "Başlangıç Yatırımı",
        },
        "years": {
          "help": "Paranın yatırımda veya tasarrufta kaldığı süre.",
          "label": "Süre (yıl)",
        },
      },
      "keywords": [
        "bileşik faiz hesaplayıcı",
        "yatırım büyümesi",
        "tasarruf hesaplayıcı",
        "gelecek değer",
        "bileşik büyüme",
        "faiz hesaplama",
        "yatırım getirisi",
      ],
      "options": {
        "compoundFrequency": {
          "annually": "Yıllık (1×/yıl)",
          "daily": "Günlük (365×/yıl)",
          "monthly": "Aylık (12×/yıl)",
          "quarterly": "Üç Aylık (4×/yıl)",
        },
      },
      "outputs": {
        "futureValue": {
          "help": "Dönem sonunda toplam hesap değeri.",
          "label": "Gelecekteki Değer",
        },
        "totalContributions": {
          "help": "Başlangıç yatırımı artı tüm aylık katkıların toplamı.",
          "label": "Toplam Katkı",
        },
        "totalInterest": {
          "help": "Bileşik faizin oluşturduğu büyüme.",
          "label": "Toplam Faiz Kazancı",
        },
        "yearlyBreakdown": {
          "help": "Her yıl için yıllık bakiye, toplam katkı ve kazanılan faiz.",
          "label": "Yıllık Dökümü",
