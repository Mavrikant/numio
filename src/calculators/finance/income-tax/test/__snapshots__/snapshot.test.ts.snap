  "inputs": [
    {
      "defaultValue": "us",
      "id": "country",
      "required": true,
      "type": {
        "kind": "select",
        "options": [
          {
            "i18nKey": "us",
            "value": "us",
          },
          {
            "i18nKey": "tr",
            "value": "tr",
          },
        ],
      },
    },
    {
      "defaultValue": 50000,
      "id": "grossIncome",
      "required": true,
      "type": {
        "kind": "number",
        "max": 100000000,
        "min": 0,
        "step": 1000,
        "unit": "usd",
      },
    },
    {
      "defaultValue": "single",
      "id": "filingStatus",
      "required": false,
      "type": {
        "kind": "select",
        "options": [
          {
            "i18nKey": "single",
            "value": "single",
          },
          {
            "i18nKey": "married",
            "value": "married",
          },
          {
            "i18nKey": "head",
            "value": "head",
          },
        ],
      },
    },
    {
      "defaultValue": 0,
      "id": "deductions",
      "required": false,
      "type": {
        "kind": "number",
        "max": 10000000,
        "min": 0,
        "step": 100,
        "unit": "usd",
      },
    },
  ],
  "meta": {
    "disclaimer": "This is an estimate of federal income tax only and does not include state/local taxes, FICA, or other deductions. Consult a tax professional for accurate filing.",
    "formulaLatex": "\\text{Tax} = \\sum_{i} \\text{rate}_i \\times \\max(0, \\min(\\text{taxableIncome}, \\text{max}_i) - \\text{min}_i)",
    "references": [
      {
        "authority": "Internal Revenue Service (IRS)",
        "title": "IRS Revenue Procedure 2023-34",
        "url": "https://www.irs.gov/newsroom/irs-provides-tax-inflation-adjustments-for-tax-year-2024",
      },
      {
        "authority": "T.C. Hazine ve Maliye Bakanlığı",
        "title": "Gelir Vergisi Kanunu",
        "url": "https://www.mevzuat.gov.tr/mevzuatmetin/1.3.193.pdf",
      },
    ],
  },
  "outputs": [
    {
      "format": "number",
      "highlight": true,
      "id": "estimatedTax",
      "precision": 2,
      "unit": "usd",
    },
    {
      "format": "number",
      "id": "effectiveRate",
      "precision": 2,
      "unit": "percent",
    },
    {
      "format": "number",
      "id": "taxableIncome",
      "precision": 2,
      "unit": "usd",
    },
    {
      "format": "number",
      "id": "afterTaxIncome",
      "precision": 2,
      "unit": "usd",
    },
  ],
  "priority": Any<String>,
  "related": [
    "salary",
    "savings-goal",
  ],
  "slug": Any<String>,
  "tags": [
    "income tax",
    "tax calculator",
