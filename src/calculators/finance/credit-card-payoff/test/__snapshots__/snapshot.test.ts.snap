    "zh": {
      "description": "免费信用卡还款计算器。输入余额、年利率和月还款额，即可查看还清月数、总利息和月度还款计划。",
      "errors": {
        "balanceOutOfRange": "余额必须在1至500,000之间。",
        "paymentTooLow": "固定还款额必须高于每月利息。",
      },
      "faq": [
        {
          "a": "最低还款额随余额减少而降低，导致大部分还款用于支付利息而非本金。",
          "q": "为什么最低还款还款期那么长？",
        },
        {
          "a": "是的。每月多还50–100元就可以节省数千元利息。",
          "q": "应该多还一些吗？",
        },
      ],
      "inputs": {
        "apr": {
          "help": "您信用卡的年利率。",
          "label": "年利率（APR）",
        },
        "balance": {
          "help": "您当前的信用卡欠款余额。",
          "label": "当前余额",
        },
        "fixedPayment": {
          "help": "每月固定还款的金额。",
          "label": "固定月还款额",
        },
        "minimumPaymentPct": {
          "help": "计算最低还款额的余额百分比，通常为1–3%。",
          "label": "最低还款比例（%）",
        },
        "paymentMode": {
          "help": "最低还款或固定月还款额。",
          "label": "还款方式",
        },
      },
      "keywords": [
        "信用卡还款计算器",
        "信用卡多久还清",
        "信用卡利息计算",
        "最低还款计算器",
        "债务还款计算器",
        "年利率计算",
        "还款计划",
      ],
      "options": {
        "paymentMode": {
          "fixed": "固定还款",
          "minimum": "最低还款",
        },
      },
      "outputs": {
        "interestSavings": {
          "help": "与只还最低还款额相比节省的利息。",
          "label": "节省的利息",
        },
        "monthsToPayoff": {
          "help": "余额归零所需的月数。",
          "label": "还清所需月数",
        },
        "totalInterest": {
          "help": "超出原始余额支付的利息。",
          "label": "总利息",
        },
        "totalPaid": {
          "help": "含利息的所有还款合计。",
          "label": "总还款额",
        },
      },
      "short": "了解还清信用卡需要多长时间以及需要支付多少利息。",
      "title": "信用卡还款计算器",
    },
  },
