          "label": "Mevcut Bakiye",
        },
        "fixedPayment": {
          "help": "Her ay ödeyeceğiniz sabit tutar.",
          "label": "Sabit Aylık Ödeme",
        },
        "minimumPaymentPct": {
          "help": "Minimum ödemeyi hesaplamak için kullanılan bakiye yüzdesi. Genellikle %1–3.",
          "label": "Minimum Ödeme Yüzdesi",
        },
        "paymentMode": {
          "help": "Minimum ödeme: her ay yalnızca minimum ödeme yapılır. Sabit ödeme: borç bitene kadar sabit tutar ödenir.",
          "label": "Ödeme Stratejisi",
        },
      },
      "keywords": [
