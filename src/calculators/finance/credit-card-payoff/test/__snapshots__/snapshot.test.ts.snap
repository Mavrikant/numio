        "何ヶ月で完済",
        "クレジットカード利息",
        "最低返済額",
        "借金返済計算機",
        "年利計算",
        "返済スケジュール",
      ],
      "options": {
        "paymentMode": {
          "fixed": "固定返済額",
          "minimum": "最低返済額",
        },
      },
      "outputs": {
        "interestSavings": {
          "help": "最低返済のみと比べた利息節約額。",
          "label": "利息節約額",
        },
        "monthsToPayoff": {
          "help": "残高がゼロになるまでの月数。",
