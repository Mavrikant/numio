    "zh": {
      "description": "免费汽车贷款计算器。输入车价、首付、以旧换新价值、利率和期限，即可查看月供和贷款总费用。",
      "errors": {
        "downPaymentExceeds": "首付和以旧换新价值之和不能超过车辆价格。",
        "rateRange": "年利率必须在 0% 至 40% 之间。",
        "termRange": "贷款期限必须在 12 至 96 个月之间。",
        "vehiclePriceRange": "车辆价格必须在 1,000 至 500,000 之间。",
      },
      "faq": [
        {
          "a": "较短期限（36–48 个月）利息总额更少，但月供较高。较长期限（60–84 个月）降低月供，但增加总利息支出。",
          "q": "汽车贷款选多长期限最好？",
        },
      ],
      "inputs": {
        "annualRate": {
          "help": "贷款机构提供的年利率。",
          "label": "年利率 (%)",
        },
        "downPayment": {
          "help": "购车时预先支付的金额。",
          "label": "首付款",
        },
        "termMonths": {
          "help": "贷款期限（月数），如 36、48、60。",
          "label": "贷款期限（月）",
        },
        "tradeInValue": {
          "help": "旧车的置换价值，用于抵减贷款金额。",
          "label": "以旧换新价值",
        },
        "vehiclePrice": {
          "help": "车辆的购买价格。",
          "label": "车辆价格",
        },
      },
      "keywords": [
        "汽车贷款计算器",
        "车贷计算",
        "月供计算",
        "汽车融资",
        "购车贷款",
        "车贷利率",
        "汽车分期计算",
      ],
      "outputs": {
        "loanAmount": {
          "help": "车价减去首付和以旧换新价值后的实际贷款额。",
          "label": "贷款金额",
        },
        "monthlyPayment": {
          "help": "每月需支付的固定金额。",
          "label": "月供",
        },
        "totalInterest": {
          "help": "贷款期内支付的利息总额。",
          "label": "总利息",
        },
        "totalPayment": {
          "help": "所有月供的总和。",
          "label": "还款总额",
        },
      },
      "short": "计算任何汽车贷款的月供、总费用和利息。",
      "title": "汽车贷款计算器",
    },
