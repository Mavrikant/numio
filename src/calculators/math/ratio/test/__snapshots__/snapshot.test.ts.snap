    "zh": {
      "description": "免费比例简化计算器。使用最大公约数将比例化简至最简形式，查看小数和百分比值。",
      "errors": {
        "invalidRatio": "两个数都必须是正整数。",
      },
      "faq": [
        {
          "a": "比例简化是通过用最大公约数除以两个数来将比例化为最简形式。例如，12:18 化简为 2:3。",
          "q": "什么是比例简化？",
        },
        {
          "a": "欧几里得算法通过重复除法和取余数，直到得到 0。GCD(12, 18)：18 mod 12 = 6，然后 12 mod 6 = 0，所以 GCD = 6。",
          "q": "什么是欧几里得算法？",
        },
        {
          "a": "1:x 形式是将比例缩放使第一个数变为 1。例如，2:3 变为 1:1.5。",
          "q": "1:x 形式是什么意思？",
        },
        {
          "a": "将第一个数除以第二个数，再乘以 100。比例 3:4 = 3÷4 = 0.75 = 75%。",
          "q": "如何将比例转换为百分比？",
        },
      ],
      "inputs": {
        "denominator": {
          "help": "比例的分母。",
          "label": "第二个数",
        },
        "numerator": {
          "help": "比例的分子。",
          "label": "第一个数",
        },
      },
      "keywords": [
        "比例简化器",
        "化简比例",
        "最简形式",
        "最大公约数计算器",
        "比例等价",
        "比例转小数",
      ],
      "options": {},
      "outputs": {
        "decimal": {
          "help": "表示为小数的比例。",
          "label": "小数值",
        },
        "oneToXForm": {
          "help": "缩放使第一个数等于1的比例。",
          "label": "1:x 形式",
        },
        "percentValue": {
          "help": "表示为百分比的比例。",
          "label": "百分比",
        },
        "simplifiedDenominator": {
          "help": "按最大公约数缩减后的第二个数。",
          "label": "化简后的第二个数",
        },
        "simplifiedNumerator": {
          "help": "按最大公约数缩减后的第一个数。",
          "label": "化简后的第一个数",
        },
        "xToOneForm": {
          "help": "缩放使第二个数等于1的比例。",
          "label": "x:1 形式",
        },
      },
      "short": "将任何比例化简到最简形式，查看等价缩放。",
      "title": "比例简化器",
    },
  },
