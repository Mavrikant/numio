      "errors": {
        "invalidMatrix": "अमान्य मैट्रिक्स आयाम या मान।",
      },
      "faq": [
        {
          "a": "मैट्रिक्स गुणन पहले मैट्रिक्स की पंक्तियों को दूसरे के स्तंभों के साथ जोड़ता है। तत्व (i,j) = पंक्ति i और स्तंभ j के उत्पादों का योग।",
          "q": "मैट्रिक्स गुणन क्या है?",
        },
        {
          "a": "सारणिक मैट्रिक्स तत्वों से गणना की गई एक अदिश मान है। 2×2 के लिए: det(A) = ad-bc। यह मैट्रिक्स की व्युत्क्रमणीयता को दर्शाता है।",
          "q": "सारणिक क्या है?",
        },
        {
          "a": "तत्व-गुणन संबंधित तत्वों को गुणा करता है। मैट्रिक्स गुणन बिंदु-गुणन नियम का उपयोग करता है।",
