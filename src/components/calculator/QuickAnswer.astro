---
/**
 * QuickAnswer.astro — A2 SEO feature
 *
 * Renders a 2-sentence direct-answer callout ABOVE the calculator form.
 * Wraps in <div data-quick-answer> so Google's AI Overviews / featured
 * snippet extractor can easily locate the concise answer.
 *
 * - Shows bundle.short (localized 1-sentence answer)
 * - If calc.meta.formulaLatex exists, renders the formula via KaTeX (server-side)
 * - No JS emitted — pure Astro server render
 */
import katex from "katex";
// Bundle KaTeX CSS locally (the npm package's dist file) instead of loading
// from CDN with a brittle SRI hash. Vite will hash and inline-link this for us.
import "katex/dist/katex.min.css";
import type { AnyCalculatorDefinition } from "@/types/calculator";
import type { Locale } from "@/config/site";
import { DEFAULT_LOCALE } from "@/config/site";

export interface Props {
  calc: AnyCalculatorDefinition;
  locale: Locale;
}

const { calc, locale } = Astro.props;
const bundle = calc.i18n[locale] ?? calc.i18n[DEFAULT_LOCALE];
const latex = calc.meta.formulaLatex;

let formulaHtml: string | null = null;
if (latex) {
  try {
    formulaHtml = katex.renderToString(latex, {
      throwOnError: false,
      displayMode: true,
      output: "html",
    });
  } catch {
    formulaHtml = null;
  }
}
---

<div
  data-quick-answer
  class="mb-6 rounded-lg border-l-4 border-blue-500 bg-blue-50 p-4 dark:bg-blue-950/30 dark:border-blue-400"
  role="note"
  aria-label="Quick answer"
>
  <p class="text-sm font-medium text-blue-900 dark:text-blue-100 leading-relaxed">
    {bundle.short}
  </p>

  {formulaHtml && (
    <div
      class="mt-3 overflow-x-auto text-blue-800 dark:text-blue-200"
      aria-label="Formula"
      set:html={formulaHtml}
    />
  )}
</div>

<!-- KaTeX CSS is now bundled via the `import "katex/dist/katex.min.css"` in
     the frontmatter above; Vite emits a hashed, locally-served stylesheet —
     no CDN, no SRI mismatch. -->
