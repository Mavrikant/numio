---
/**
 * AuthorityFooter.astro — A1 SEO / E-E-A-T feature
 *
 * Renders trust and authority signals below calculator content:
 *  1. Formula — expandable <details> block with KaTeX-rendered LaTeX (server-side)
 *  2. Sources & References — bulleted list with linked titles + authority labels
 *  3. Accuracy note — info-styled callout (if present)
 *  4. Disclaimer — warning-styled callout (if present)
 *  5. Last reviewed — build-time date + editorial team attribution
 *
 * Pure server render — zero client JS. KaTeX CSS injected via slot="head".
 */
import katex from "katex";
import type { AnyCalculatorDefinition } from "@/types/calculator";
import type { Locale } from "@/config/site";
import { DEFAULT_LOCALE } from "@/config/site";
import { t } from "@/lib/i18n";

export interface Props {
  calc: AnyCalculatorDefinition;
  locale: Locale;
}

const { calc, locale } = Astro.props;

// Build-time date (YYYY-MM-DD)
const lastReviewed = new Date().toISOString().slice(0, 10);

// i18n labels
const labelFormula = t(locale, "authority.formula");
const labelSources = t(locale, "authority.sources");
const labelAccuracyNote = t(locale, "authority.accuracyNote");
const labelDisclaimer = t(locale, "authority.disclaimer");
const labelLastReviewed = t(locale, "authority.lastReviewed");
const labelEditorialTeam = t(locale, "authority.editorialTeam");

// KaTeX render (server-side, no client JS)
const latex = calc.meta.formulaLatex;
let formulaHtml: string | null = null;
if (latex) {
  try {
    formulaHtml = katex.renderToString(latex, {
      throwOnError: false,
      displayMode: true,
      output: "html",
    });
  } catch {
    formulaHtml = null;
  }
}

const refs = calc.meta.references ?? [];
const hasRefs = refs.length > 0;
const accuracyNote = calc.meta.accuracyNote;
const disclaimer = calc.meta.disclaimer;

// Only render the footer if there's at least something to show
const hasContent = formulaHtml || hasRefs || accuracyNote || disclaimer;
---

{hasContent && (
  <aside
    class="mt-10 border-t border-slate-200 pt-8 dark:border-slate-700"
    aria-label="Authority & Trust information"
    data-authority-footer
  >
    <div class="space-y-6">

      {/* Formula */}
      {formulaHtml && (
        <div>
          <details class="group rounded-lg border border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
            <summary
              class="flex cursor-pointer select-none items-center justify-between gap-2 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700/50 rounded-lg"
            >
              <span>{labelFormula}</span>
              <!-- chevron rotates when open -->
              <svg
                class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180 dark:text-slate-500"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <div
              class="overflow-x-auto px-4 pb-4 pt-2 text-slate-800 dark:text-slate-200"
              aria-label={labelFormula}
              set:html={formulaHtml}
            />
          </details>
        </div>
      )}

      {/* Sources & References */}
      {hasRefs && (
        <div>
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
            {labelSources}
          </h3>
          <ul class="space-y-2">
            {refs.map((ref) => (
              <li class="flex flex-col gap-0.5 text-sm">
                {ref.url ? (
                  <a
                    href={ref.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-blue-700 hover:underline dark:text-blue-400"
                  >
                    {ref.title}
                  </a>
                ) : (
                  <span class="font-medium text-slate-700 dark:text-slate-300">
                    {ref.title}
                  </span>
                )}
                {ref.authority && (
                  <span class="text-xs text-slate-500 dark:text-slate-400">
                    {ref.authority}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Accuracy note */}
      {accuracyNote && (
        <div
          class="rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-900 dark:bg-blue-950/30"
          role="note"
        >
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">
            {labelAccuracyNote}
          </p>
          <p class="text-sm text-blue-900 dark:text-blue-200">
            {accuracyNote}
          </p>
        </div>
      )}

      {/* Disclaimer */}
      {disclaimer && (
        <div
          class="rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-900 dark:bg-amber-950/30"
          role="note"
        >
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-400">
            {labelDisclaimer}
          </p>
          <p class="text-sm text-amber-900 dark:text-amber-200">
            {disclaimer}
          </p>
        </div>
      )}

      {/* Last reviewed */}
      <p class="text-xs text-slate-400 dark:text-slate-500">
        {labelLastReviewed}: <time datetime={lastReviewed}>{lastReviewed}</time> {labelEditorialTeam}.
      </p>

    </div>
  </aside>
)}

<!-- KaTeX styles — injected into <head> once per page -->
{formulaHtml && (
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
    integrity="sha384-5TcZemv2l/9On385z///+d7MSYlvIxqG3IJHU0mRjVk7lTTuOHhxPDgMEI5klAJ"
    crossorigin="anonymous"
    slot="head"
  />
)}
