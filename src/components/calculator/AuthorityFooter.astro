---
/**
 * AuthorityFooter.astro — A1 SEO / E-E-A-T feature
 *
 * Renders trust and authority signals below calculator content:
 *  1. Sources & References — bulleted list with linked titles + authority labels
 *  2. Accuracy note — info-styled callout (if present)
 *  3. Disclaimer — warning-styled callout (if present)
 *  4. Last reviewed — build-time date + editorial team attribution
 *
 * The formula is intentionally NOT rendered here — it already appears in the
 * QuickAnswer block above the calculator form, so duplicating it at the bottom
 * of every page is redundant.
 *
 * Pure server render — zero client JS.
 */
import type { AnyCalculatorDefinition } from "@/types/calculator";
import type { Locale } from "@/config/site";
import { t } from "@/lib/i18n";

export interface Props {
  calc: AnyCalculatorDefinition;
  locale: Locale;
}

const { calc, locale } = Astro.props;

// Build-time stamp. The `datetime` attribute keeps full ISO (UTC) for
// SEO + JSON-LD; the visible text starts as a UTC YYYY-MM-DD fallback
// and the shared `data-local-datetime` script in Footer.astro swaps it
// to the visitor's local timezone after hydration.
const lastReviewedIso = new Date().toISOString();
const lastReviewed = lastReviewedIso.slice(0, 10);

// i18n labels
const labelSources = t(locale, "authority.sources");
const labelAccuracyNote = t(locale, "authority.accuracyNote");
const labelDisclaimer = t(locale, "authority.disclaimer");
const labelLastReviewed = t(locale, "authority.lastReviewed");
const labelEditorialTeam = t(locale, "authority.editorialTeam");

const refs = calc.meta.references ?? [];
const hasRefs = refs.length > 0;
const accuracyNote = calc.meta.accuracyNote;
const disclaimer = calc.meta.disclaimer;

// Only render the footer if there's at least something to show
const hasContent = hasRefs || accuracyNote || disclaimer;
---

{hasContent && (
  <aside
    class="mt-10 border-t border-slate-200 pt-8 dark:border-slate-700"
    aria-label="Authority & Trust information"
    data-authority-footer
  >
    <div class="space-y-6">

      {/* Sources & References */}
      {hasRefs && (
        <div>
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
            {labelSources}
          </h3>
          <ul class="space-y-2">
            {refs.map((ref) => (
              <li class="flex flex-col gap-0.5 text-sm">
                {ref.url ? (
                  <a
                    href={ref.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-blue-700 hover:underline dark:text-blue-400"
                  >
                    {ref.title}
                  </a>
                ) : (
                  <span class="font-medium text-slate-700 dark:text-slate-300">
                    {ref.title}
                  </span>
                )}
                {ref.authority && (
                  <span class="text-xs text-slate-500 dark:text-slate-400">
                    {ref.authority}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Accuracy note */}
      {accuracyNote && (
        <div
          class="rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-900 dark:bg-blue-950/30"
          role="note"
        >
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">
            {labelAccuracyNote}
          </p>
          <p class="text-sm text-blue-900 dark:text-blue-200">
            {accuracyNote}
          </p>
        </div>
      )}

      {/* Disclaimer */}
      {disclaimer && (
        <div
          class="rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-900 dark:bg-amber-950/30"
          role="note"
        >
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-400">
            {labelDisclaimer}
          </p>
          <p class="text-sm text-amber-900 dark:text-amber-200">
            {disclaimer}
          </p>
        </div>
      )}

      {/* Last reviewed — rendered in the visitor's local timezone by the
          shared `data-local-datetime` enhancement in chrome/Footer.astro. */}
      <p class="text-xs text-slate-400 dark:text-slate-500">
        {labelLastReviewed}:{" "}
        <time
          datetime={lastReviewedIso}
          data-local-datetime
          data-local-format="date"
        >
          {lastReviewed}
        </time>{" "}
        {labelEditorialTeam}.
      </p>

    </div>
  </aside>
)}
