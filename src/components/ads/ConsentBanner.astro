---
/**
 * ConsentBanner.astro
 * GDPR-friendly, mobile-first consent banner (sticky bottom).
 *
 * Consent types (granular opt-in):
 *   - essential   : always on, no toggle
 *   - analytics   : opt-in
 *   - ads         : opt-in
 *
 * Persisted in localStorage with 30-day TTL:
 *   ads-consent          : "accepted" | "rejected" | "unset"
 *   ads-consent-ttl      : epoch ms of expiry
 *   analytics-consent    : "accepted" | "rejected"
 *   consent-version      : bump this to re-ask after policy changes
 *
 * Accessibility:
 *   - role="dialog" aria-modal="true" aria-labelledby
 *   - Focus trap inside the dialog
 *   - ESC closes (rejects non-essential)
 *
 * i18n: uses t() via Astro props (locale passed in).
 */

import type { Locale } from "../../lib/i18n";
import { t } from "../../lib/i18n";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const i = (key: string) => t(locale, `consent.${key}`);
---

<div
  id="consent-banner"
  role="dialog"
  aria-modal="true"
  aria-labelledby="consent-title"
  class="consent-banner"
  hidden
>
  <!-- Simple view -->
  <div id="consent-simple" class="consent-panel">
    <div class="consent-body">
      <h2 id="consent-title" class="consent-title">{i("title")}</h2>
      <p class="consent-desc">{i("description")}</p>
      <a
        href="/privacy"
        class="consent-privacy-link"
        target="_blank"
        rel="noopener noreferrer"
      >{i("privacyPolicy")}</a>
    </div>

    <div class="consent-actions">
      <button id="consent-accept-all" class="btn-consent btn-accept">
        {i("accept")}
      </button>
      <button id="consent-reject-all" class="btn-consent btn-reject">
        {i("reject")}
      </button>
      <button id="consent-customize-open" class="btn-consent btn-customize">
        {i("customize")}
      </button>
    </div>
  </div>

  <!-- Customize view -->
  <div id="consent-customize" class="consent-panel" hidden>
    <div class="consent-body">
      <h2 class="consent-title">{i("customizeTitle")}</h2>

      <!-- Essential (always on) -->
      <label class="consent-toggle-row">
        <span class="consent-toggle-label">
          <strong>{i("essential")}</strong>
          <span class="consent-toggle-desc">{i("essentialDesc")}</span>
        </span>
        <input type="checkbox" checked disabled aria-checked="true" />
      </label>

      <!-- Analytics -->
      <label class="consent-toggle-row">
        <span class="consent-toggle-label">
          <strong>{i("analytics")}</strong>
          <span class="consent-toggle-desc">{i("analyticsDesc")}</span>
        </span>
        <input type="checkbox" id="consent-analytics-toggle" />
      </label>

      <!-- Ads -->
      <label class="consent-toggle-row">
        <span class="consent-toggle-label">
          <strong>{i("ads")}</strong>
          <span class="consent-toggle-desc">{i("adsDesc")}</span>
        </span>
        <input type="checkbox" id="consent-ads-toggle" />
      </label>
    </div>

    <div class="consent-actions">
      <button id="consent-save-prefs" class="btn-consent btn-accept">
        {i("savePreferences")}
      </button>
      <button id="consent-customize-back" class="btn-consent btn-customize">
        {i("back")}
      </button>
    </div>
  </div>
</div>

<!-- Overlay -->
<div id="consent-overlay" class="consent-overlay" hidden aria-hidden="true"></div>

<script is:inline>
  (function () {
    var CONSENT_KEY = "ads-consent";
    var CONSENT_TTL_KEY = "ads-consent-ttl";
    var ANALYTICS_KEY = "analytics-consent";
    var CONSENT_VERSION_KEY = "consent-version";
    var CURRENT_VERSION = "1";
    var TTL_MS = 30 * 24 * 60 * 60 * 1000; // 30 days

    var banner = document.getElementById("consent-banner");
    var overlay = document.getElementById("consent-overlay");
    var simplePanel = document.getElementById("consent-simple");
    var customizePanel = document.getElementById("consent-customize");

    var btnAcceptAll = document.getElementById("consent-accept-all");
    var btnRejectAll = document.getElementById("consent-reject-all");
    var btnCustomizeOpen = document.getElementById("consent-customize-open");
    var btnCustomizeBack = document.getElementById("consent-customize-back");
    var btnSavePrefs = document.getElementById("consent-save-prefs");

    var analyticsToggle = document.getElementById("consent-analytics-toggle");
    var adsToggle = document.getElementById("consent-ads-toggle");

    // -- helpers --

    function readConsent() {
      try {
        var ttl = parseInt(localStorage.getItem(CONSENT_TTL_KEY) || "0", 10);
        if (Date.now() > ttl) return null; // expired
        var version = localStorage.getItem(CONSENT_VERSION_KEY);
        if (version !== CURRENT_VERSION) return null; // policy changed
        return localStorage.getItem(CONSENT_KEY); // "accepted"|"rejected"
      } catch (e) {
        return null;
      }
    }

    function saveConsent(ads, analytics) {
      try {
        var expiry = Date.now() + TTL_MS;
        localStorage.setItem(CONSENT_KEY, ads);
        localStorage.setItem(CONSENT_TTL_KEY, String(expiry));
        localStorage.setItem(ANALYTICS_KEY, analytics);
        localStorage.setItem(CONSENT_VERSION_KEY, CURRENT_VERSION);
      } catch (e) {}
    }

    function hideBanner() {
      if (banner) banner.hidden = true;
      if (overlay) overlay.hidden = true;
      // Restore focus to the element that had focus before the banner appeared
      if (window.__consentPrevFocus && window.__consentPrevFocus.focus) {
        try { window.__consentPrevFocus.focus(); } catch (e) {}
      }
    }

    function acceptAll() {
      saveConsent("accepted", "accepted");
      window.dispatchEvent(new CustomEvent("ads-consent-accepted"));
      window.dispatchEvent(new CustomEvent("analytics-consent-accepted"));
      hideBanner();
    }

    function rejectAll() {
      saveConsent("rejected", "rejected");
      hideBanner();
    }

    function savePreferences() {
      var adsVal = adsToggle && adsToggle.checked ? "accepted" : "rejected";
      var analyticsVal = analyticsToggle && analyticsToggle.checked ? "accepted" : "rejected";
      saveConsent(adsVal, analyticsVal);
      if (adsVal === "accepted") {
        window.dispatchEvent(new CustomEvent("ads-consent-accepted"));
      }
      if (analyticsVal === "accepted") {
        window.dispatchEvent(new CustomEvent("analytics-consent-accepted"));
      }
      hideBanner();
    }

    // -- focus trap --

    function getFocusable(container) {
      return Array.from(
        container.querySelectorAll(
          'button:not([disabled]), [href], input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function trapFocus(e) {
      if (!banner || banner.hidden) return;
      var focusable = getFocusable(banner);
      if (!focusable.length) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.key === "Tab") {
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
      if (e.key === "Escape") {
        rejectAll();
      }
    }

    // -- panel switch --

    function showCustomize() {
      if (simplePanel) simplePanel.hidden = true;
      if (customizePanel) customizePanel.hidden = false;
      var focusable = getFocusable(customizePanel || banner);
      if (focusable[0]) focusable[0].focus();
    }

    function showSimple() {
      if (customizePanel) customizePanel.hidden = true;
      if (simplePanel) simplePanel.hidden = false;
      var focusable = getFocusable(simplePanel || banner);
      if (focusable[0]) focusable[0].focus();
    }

    // -- init --

    function init() {
      var existing = readConsent();
      if (existing !== null) return; // already decided

      // Save previously focused element
      window.__consentPrevFocus = document.activeElement;

      if (banner) banner.hidden = false;
      if (overlay) overlay.hidden = false;

      // Focus first focusable element in banner
      setTimeout(function () {
        var focusable = getFocusable(banner);
        if (focusable[0]) focusable[0].focus();
      }, 50);

      document.addEventListener("keydown", trapFocus);
    }

    // Event bindings
    if (btnAcceptAll) btnAcceptAll.addEventListener("click", acceptAll);
    if (btnRejectAll) btnRejectAll.addEventListener("click", rejectAll);
    if (btnCustomizeOpen) btnCustomizeOpen.addEventListener("click", showCustomize);
    if (btnCustomizeBack) btnCustomizeBack.addEventListener("click", showSimple);
    if (btnSavePrefs) btnSavePrefs.addEventListener("click", savePreferences);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>

<style>
  .consent-overlay {
    position: fixed;
    inset: 0;
    background: rgb(0 0 0 / 0.4);
    z-index: 998;
  }

  .consent-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: rgb(var(--bg));
    color: rgb(var(--fg));
    border-top: 1px solid rgb(var(--border));
    box-shadow: 0 -4px 24px rgb(0 0 0 / 0.12);
    padding: 1rem;
    max-height: 90dvh;
    overflow-y: auto;
  }

  @media (min-width: 640px) {
    .consent-banner {
      max-width: 560px;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      border-radius: 1rem 1rem 0 0;
    }
  }

  .consent-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .consent-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .consent-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  .consent-desc {
    font-size: 0.875rem;
    color: rgb(var(--muted));
    margin: 0;
    line-height: 1.5;
  }

  .consent-privacy-link {
    font-size: 0.8125rem;
    color: rgb(var(--accent));
    text-decoration: underline;
  }

  .consent-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .btn-consent {
    flex: 1 1 auto;
    min-width: 7rem;
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .btn-consent:hover {
    opacity: 0.85;
  }

  .btn-accept {
    background: rgb(var(--accent));
    color: #fff;
  }

  .btn-reject {
    background: rgb(var(--border));
    color: rgb(var(--fg));
  }

  .btn-customize {
    background: transparent;
    color: rgb(var(--muted));
    border: 1px solid rgb(var(--border));
  }

  /* Toggle rows */
  .consent-toggle-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgb(var(--border) / 0.5);
    cursor: pointer;
  }

  .consent-toggle-label {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.875rem;
  }

  .consent-toggle-desc {
    font-size: 0.8125rem;
    color: rgb(var(--muted));
    font-weight: 400;
  }

  /* Checkbox styled as toggle */
  .consent-toggle-row input[type="checkbox"] {
    flex-shrink: 0;
    appearance: none;
    -webkit-appearance: none;
    width: 2.5rem;
    height: 1.375rem;
    border-radius: 9999px;
    background: rgb(var(--border));
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 2px;
  }

  .consent-toggle-row input[type="checkbox"]:checked {
    background: rgb(var(--accent));
  }

  .consent-toggle-row input[type="checkbox"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .consent-toggle-row input[type="checkbox"]::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 1rem;
    height: 1rem;
    border-radius: 9999px;
    background: white;
    transition: transform 0.2s;
  }

  .consent-toggle-row input[type="checkbox"]:checked::after {
    transform: translateX(1.125rem);
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .btn-consent,
    .consent-toggle-row input[type="checkbox"],
    .consent-toggle-row input[type="checkbox"]::after {
      transition: none;
    }
  }
</style>
