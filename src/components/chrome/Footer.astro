---
import { t, buildPath, getCategoryLabel, type Locale } from "@/lib/i18n";
import { getAvailableCategories } from "@/lib/registry";
import { BUILD_TIME } from "@/config/build";
import { formatDate, bcp47 } from "@/lib/format";
import LanguageSwitcher from "./LanguageSwitcher.astro";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const categories = getAvailableCategories();
const currentYear = new Date().getFullYear();

const buildDate = new Date(BUILD_TIME);
const buildHuman = formatDate(buildDate, locale, {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
});
const buildIsoForAttr = BUILD_TIME;
---

<footer
  id="site-footer"
  class="mt-16 border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900 print:hidden"
>
  <div class="container-page py-10">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3">
      {/* Brand column */}
      <div class="flex flex-col gap-3">
        <a
          href={buildPath(locale)}
          class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-100 hover:opacity-80 transition-opacity w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-brand-600 dark:text-brand-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="4" y="2" width="16" height="20" rx="2" />
            <line x1="8" y1="6" x2="16" y2="6" />
            <line x1="8" y1="10" x2="8" y2="10" />
            <line x1="12" y1="10" x2="12" y2="10" />
            <line x1="16" y1="10" x2="16" y2="10" />
            <line x1="8" y1="14" x2="8" y2="14" />
            <line x1="12" y1="14" x2="12" y2="14" />
            <line x1="16" y1="14" x2="16" y2="14" />
            <line x1="8" y1="18" x2="12" y2="18" />
            <line x1="16" y1="18" x2="16" y2="18" />
          </svg>
          <span class="text-sm">{t(locale, "site.name")}</span>
        </a>
        <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed max-w-xs">
          {t(locale, "footer.disclaimer")}
        </p>
      </div>

      {/* Categories column */}
      {
        categories.length > 0 && (
          <div class="flex flex-col gap-3">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
              {t(locale, "nav.categories")}
            </h2>
            <ul class="flex flex-col gap-2" role="list">
              {categories.map((cat) => (
                <li>
                  <a
                    href={buildPath(locale, cat)}
                    class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition-colors"
                  >
                    {getCategoryLabel(locale, cat)}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {/* Links column */}
      <div class="flex flex-col gap-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
          {t(locale, "footer.links")}
        </h2>
        <ul class="flex flex-col gap-2" role="list">
          <li>
            <a
              href={buildPath(locale, "about")}
              class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition-colors"
            >
              {t(locale, "nav.about")}
            </a>
          </li>
          <li>
            <a
              href={buildPath(locale, "contact")}
              class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition-colors"
            >
              {t(locale, "nav.contact")}
            </a>
          </li>
          <li>
            <a
              href={buildPath(locale, "privacy")}
              class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition-colors"
            >
              {t(locale, "nav.privacy")}
            </a>
          </li>
          <li>
            <a
              href={buildPath(locale, "sitemap")}
              class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition-colors"
            >
              {t(locale, "nav.sitemap")}
            </a>
          </li>
        </ul>

        {/* Compact language switcher */}
        <div class="mt-2">
          <LanguageSwitcher locale={locale} compact={true} />
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="mt-8 flex flex-col flex-wrap items-center justify-between gap-2 sm:gap-4 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800 dark:text-slate-400 sm:flex-row">
      <p>
        {t(locale, "footer.copyright")} {currentYear}
      </p>

      {/* PWA install button — hidden by default; JS shows it on supported browsers */}
      <button
        id="pwa-install-btn"
        onclick="window._triggerPwaInstall && window._triggerPwaInstall()"
        class="hidden items-center gap-1.5 rounded-md border border-brand-500 px-3 py-2 sm:py-1.5 text-sm sm:text-xs min-h-[44px] sm:min-h-0 font-medium text-brand-600 transition-colors hover:bg-brand-50 dark:border-brand-400 dark:text-brand-400 dark:hover:bg-brand-950"
        aria-label={t(locale, "pwa.install")}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2v13m0 0-4-4m4 4 4-4"/>
          <rect x="3" y="16" width="18" height="6" rx="2"/>
        </svg>
        {t(locale, "pwa.install")}
      </button>

      <p>
        {t(locale, "footer.lastUpdated")}:{" "}
        <time
          datetime={buildIsoForAttr}
          lang={bcp47(locale)}
          data-local-datetime
          data-local-format="datetime"
        >
          {buildHuman}
        </time>
      </p>
    </div>
  </div>
</footer>

<!--
  Client-side conversion of build-time UTC stamps into the visitor's
  local timezone. We bake a deterministic UTC string at build time (good
  for SEO + JSON-LD) and progressively enhance it after hydration so
  users see the timestamp in their own clock.

  Marker: `<time data-local-datetime data-local-format="date|datetime">`
  Source of truth: the `datetime` attribute (ISO 8601 UTC).
  Locale: `<html lang>` so a Turkish page still says "27 May 2026", just
  in Europe/Istanbul time instead of UTC.
-->
<script is:inline>
  (function () {
    function localize() {
      var nodes = document.querySelectorAll("time[data-local-datetime]");
      if (!nodes.length) return;
      var pageLang = document.documentElement.lang || undefined;
      for (var i = 0; i < nodes.length; i++) {
        var el = nodes[i];
        var iso = el.getAttribute("datetime");
        if (!iso) continue;
        var d = new Date(iso);
        if (isNaN(d.getTime())) continue;
        var format = el.getAttribute("data-local-format") || "datetime";
        var opts =
          format === "date"
            ? { year: "numeric", month: "short", day: "numeric" }
            : {
                year: "numeric",
                month: "short",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false,
              };
        try {
          el.textContent = new Intl.DateTimeFormat(pageLang, opts).format(d);
        } catch (_) {
          /* leave SSR fallback in place */
        }
      }
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", localize, { once: true });
    } else {
      localize();
    }
  })();
</script>
