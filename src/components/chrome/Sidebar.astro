---
/**
 * Sidebar — lists all calculators grouped by category.
 * Sticky on lg+ screens, hidden on mobile (the header hamburger covers mobile nav).
 */
import {
  getAllCalculators,
  getCalculatorsByCategory,
} from "@/lib/registry";
import { CATEGORIES } from "@/types/calculator";
import {
  buildPath,
  getLocalizedSlug,
  t,
  getCategoryLabel,
  type Locale,
} from "@/lib/i18n";

export interface Props {
  locale: Locale;
  /** Slug of the active calculator (for highlight). Optional. */
  activeSlug?: string;
  /** Active category for highlight. Optional. */
  activeCategory?: string;
}

const { locale, activeSlug, activeCategory } = Astro.props;

// Pre-build category → calculators list. Empty categories are shown with
// a "Coming soon" label so the user sees the full plan.
const allCalcs = getAllCalculators();
const totalCount = allCalcs.length;
---

<aside
  class="sidebar w-full lg:w-64 lg:shrink-0"
  aria-label={t(locale, "footer.allCalculators")}
>
  <div class="lg:sticky lg:top-20 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto">
    <nav class="space-y-4 rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900">
      <header class="flex items-baseline justify-between">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
          {t(locale, "footer.allCalculators")}
        </h2>
        <span class="text-xs text-slate-400 tabular-nums">{totalCount}</span>
      </header>

      <ul class="space-y-3" role="list">
        {
          CATEGORIES.map((cat) => {
            const calcs = getCalculatorsByCategory(cat);
            const catLabel = getCategoryLabel(locale, cat);
            const catActive = activeCategory === cat;
            return (
              <li>
                <a
                  href={buildPath(locale, cat)}
                  class:list={[
                    "block rounded-md px-2 py-1 text-xs font-semibold uppercase tracking-wider transition-colors",
                    catActive
                      ? "bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300"
                      : "text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800",
                  ]}
                  aria-current={catActive ? "page" : undefined}
                >
                  {catLabel}
                </a>
                {calcs.length === 0 ? (
                  <p class="ms-2 mt-1 text-xs italic text-slate-400">
                    {t(locale, "footer.comingSoon")}
                  </p>
                ) : (
                  <ul class="ms-2 mt-1 space-y-0.5 border-s border-slate-200 ps-3 dark:border-slate-800" role="list">
                    {calcs.map((calc) => {
                      const localizedSlug = getLocalizedSlug(calc.slug, locale);
                      const bundle = calc.i18n[locale] ?? calc.i18n["en"];
                      const isActive = activeSlug === calc.slug;
                      return (
                        <li>
                          <a
                            href={buildPath(locale, calc.category, localizedSlug)}
                            class:list={[
                              "block rounded-md px-2 py-1 text-sm transition-colors",
                              isActive
                                ? "bg-brand-100 font-medium text-brand-800 dark:bg-brand-900/40 dark:text-brand-200"
                                : "text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100",
                            ]}
                            aria-current={isActive ? "page" : undefined}
                          >
                            {bundle.title}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</aside>
