---
import { t, buildPath, type Locale } from "@/lib/i18n";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import CategoryNav from "./CategoryNav.astro";

export interface Props {
  locale: Locale;
  activeCategory?: string | undefined;
}

const { locale, activeCategory } = Astro.props;
const homeHref = buildPath(locale);
const siteName = t(locale, "site.name");
const searchIndexUrl = `${buildPath(locale)}search-index.json`;
---

<header
  id="site-header"
  class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/95 backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/95 print:hidden"
>
  <div class="container-page">
    {/* Main header row */}
    <div class="flex h-14 items-center justify-between gap-4">
      {/* Logo + site name */}
      <a
        href={homeHref}
        class="flex shrink-0 items-center gap-2 font-semibold text-slate-900 dark:text-slate-100 hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded"
        aria-label={siteName}
      >
        {/* Calculator icon */}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6 text-brand-600 dark:text-brand-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="4" y="2" width="16" height="20" rx="2" />
          <line x1="8" y1="6" x2="16" y2="6" />
          <line x1="8" y1="10" x2="8" y2="10" />
          <line x1="12" y1="10" x2="12" y2="10" />
          <line x1="16" y1="10" x2="16" y2="10" />
          <line x1="8" y1="14" x2="8" y2="14" />
          <line x1="12" y1="14" x2="12" y2="14" />
          <line x1="16" y1="14" x2="16" y2="14" />
          <line x1="8" y1="18" x2="12" y2="18" />
          <line x1="16" y1="18" x2="16" y2="18" />
        </svg>
        <span class="text-base">{siteName}</span>
      </a>

      {/* Desktop nav — hidden on mobile */}
      <nav
        aria-label={t(locale, "nav.mainNavigation")}
        class="hidden md:flex md:items-center md:gap-1"
      >
        <a
          href={homeHref}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors"
        >
          {t(locale, "nav.home")}
        </a>
        <a
          href={`${buildPath(locale)}tools/`}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors"
        >
          {t(locale, "nav.tools")}
        </a>
      </nav>

      {/* Right controls */}
      <div class="flex items-center gap-1">
        {/* Search */}
        <button
          id="search-btn"
          type="button"
          aria-label={t(locale, "nav.search")}
          aria-haspopup="dialog"
          aria-controls="search-dialog"
          class="inline-flex h-10 w-10 sm:h-9 sm:w-9 items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
        </button>

        <ThemeToggle locale={locale} />
        <LanguageSwitcher locale={locale} class="hidden sm:block" />

        {/* Mobile hamburger */}
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label={t(locale, "nav.openMenu")}
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="inline-flex h-10 w-10 sm:h-9 sm:w-9 items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 md:hidden"
        >
          <svg
            id="hamburger-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
          <svg
            id="close-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>

    {/* Category nav bar — always visible below main row */}
    <div class="border-t border-slate-100 py-2 dark:border-slate-800">
      <CategoryNav locale={locale} activeCategory={activeCategory} />
    </div>
  </div>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 md:hidden"
    aria-label={t(locale, "nav.mainNavigation")}
  >
    <div class="container-page py-4 space-y-4">
      <nav class="flex flex-col gap-1">
        <a
          href={homeHref}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-colors"
        >
          {t(locale, "nav.home")}
        </a>
        <a
          href={`${buildPath(locale)}tools/`}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-colors"
        >
          {t(locale, "nav.tools")}
        </a>
      </nav>

      <div class="border-t border-slate-100 pt-4 dark:border-slate-800">
        <LanguageSwitcher locale={locale} class="w-full" />
      </div>
    </div>
  </div>
</header>

{/* Search dialog */}
<div
  id="search-dialog"
  class="fixed inset-0 z-50 hidden print:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={t(locale, "nav.search")}
  data-index-url={searchIndexUrl}
  data-no-results={t(locale, "search.noResults")}
>
  <div id="search-backdrop" class="absolute inset-0 bg-slate-900/50"></div>
  <div class="relative mx-auto mt-16 w-full max-w-xl px-4 sm:mt-24">
    <div
      class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-2xl dark:border-slate-700 dark:bg-slate-900"
    >
      <div class="flex items-center gap-3 px-4">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 shrink-0 text-slate-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder={t(locale, "search.placeholder")}
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          role="combobox"
          aria-expanded="false"
          aria-controls="search-results"
          aria-autocomplete="list"
          class="h-12 w-full bg-transparent text-base text-slate-900 placeholder:text-slate-400 focus:outline-none dark:text-slate-100 dark:placeholder:text-slate-500"
        />
      </div>
      <ul
        id="search-results"
        role="listbox"
        class="max-h-80 overflow-y-auto overscroll-contain border-t border-slate-200 p-2 empty:hidden dark:border-slate-700"
      >
      </ul>
    </div>
  </div>
</div>

<script>
  // Header: sticky shadow on scroll + mobile menu toggle
  const header = document.getElementById("site-header");
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  // Sticky shadow
  if (header) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry && !entry.isIntersecting) {
          header.classList.add("shadow-sm");
        } else {
          header.classList.remove("shadow-sm");
        }
      },
      { threshold: 0, rootMargin: "-1px 0px 0px 0px" },
    );
    // Sentinel element trick: observe a zero-height element at the top of the page
    const sentinel = document.createElement("div");
    sentinel.style.height = "1px";
    sentinel.style.position = "absolute";
    sentinel.style.top = "0";
    sentinel.style.pointerEvents = "none";
    document.body.prepend(sentinel);
    observer.observe(sentinel);
  }

  // Mobile menu toggle
  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    menuBtn?.setAttribute("aria-expanded", "true");
    menuBtn?.setAttribute("aria-label", menuBtn.dataset.closeLabel ?? "Close menu");
    hamburgerIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    menuBtn?.setAttribute("aria-expanded", "false");
    menuBtn?.setAttribute("aria-label", menuBtn.dataset.openLabel ?? "Open menu");
    hamburgerIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  menuBtn?.addEventListener("click", () => {
    const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  // Close mobile menu on resize to desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) closeMenu();
  });

  // Site search
  const searchBtn = document.getElementById("search-btn");
  const searchDialog = document.getElementById("search-dialog");
  const searchBackdrop = document.getElementById("search-backdrop");
  const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
  const searchResults = document.getElementById("search-results");

  interface SearchEntry {
    title: string;
    short: string;
    category: string;
    keywords: string;
    href: string;
  }

  let searchEntries: SearchEntry[] = [];
  let searchIndexPromise: Promise<SearchEntry[]> | null = null;
  let activeResult = -1;

  function loadSearchIndex(): Promise<SearchEntry[]> {
    if (!searchIndexPromise) {
      const url = searchDialog?.dataset.indexUrl ?? "";
      searchIndexPromise = fetch(url)
        .then((res) => {
          if (!res.ok) throw new Error(`Search index fetch failed: ${res.status}`);
          return res.json();
        })
        .then((data: SearchEntry[]) => {
          searchEntries = data;
          return data;
        })
        .catch((err) => {
          searchIndexPromise = null;
          console.error(err);
          return [];
        });
    }
    return searchIndexPromise;
  }

  function openSearch() {
    if (!searchDialog) return;
    closeMenu();
    searchDialog.classList.remove("hidden");
    searchInput?.focus();
    searchInput?.select();
    void loadSearchIndex().then(() => renderResults(searchInput?.value ?? ""));
  }

  function closeSearch() {
    searchDialog?.classList.add("hidden");
    searchInput?.setAttribute("aria-expanded", "false");
  }

  function scoreEntry(entry: SearchEntry, tokens: string[]): number {
    const title = entry.title.toLowerCase();
    const haystack =
      `${title} ${entry.short} ${entry.keywords} ${entry.category}`.toLowerCase();
    let score = 0;
    for (const token of tokens) {
      if (!haystack.includes(token)) return -1;
      if (title.startsWith(token)) score += 3;
      else if (title.includes(token)) score += 2;
      else score += 1;
    }
    return score;
  }

  function setActiveResult(index: number) {
    if (!searchResults) return;
    const options = searchResults.querySelectorAll<HTMLElement>("[role='option']");
    activeResult = index;
    options.forEach((option, i) => {
      const isActive = i === index;
      option.setAttribute("aria-selected", String(isActive));
      option.classList.toggle("bg-slate-100", isActive);
      option.classList.toggle("dark:bg-slate-800", isActive);
      if (isActive) option.scrollIntoView({ block: "nearest" });
    });
  }

  function renderResults(query: string) {
    if (!searchResults) return;
    searchResults.textContent = "";
    activeResult = -1;

    const tokens = query.trim().toLowerCase().split(/\s+/).filter(Boolean);
    if (tokens.length === 0) {
      searchInput?.setAttribute("aria-expanded", "false");
      return;
    }

    const matches = searchEntries
      .map((entry) => ({ entry, score: scoreEntry(entry, tokens) }))
      .filter((m) => m.score >= 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 10);

    searchInput?.setAttribute("aria-expanded", "true");

    if (matches.length === 0) {
      const li = document.createElement("li");
      li.className = "px-3 py-4 text-center text-sm text-slate-500 dark:text-slate-400";
      li.textContent = searchDialog?.dataset.noResults ?? "No results found.";
      searchResults.appendChild(li);
      return;
    }

    for (const { entry } of matches) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = entry.href;
      a.setAttribute("role", "option");
      a.setAttribute("aria-selected", "false");
      a.className =
        "flex items-baseline justify-between gap-3 rounded-lg px-3 py-2 hover:bg-slate-100 dark:hover:bg-slate-800";

      const title = document.createElement("span");
      title.className = "truncate text-sm font-medium text-slate-900 dark:text-slate-100";
      title.textContent = entry.title;

      const category = document.createElement("span");
      category.className = "shrink-0 text-xs text-slate-500 dark:text-slate-400";
      category.textContent = entry.category;

      a.append(title, category);
      li.appendChild(a);
      searchResults.appendChild(li);
    }
  }

  searchBtn?.addEventListener("click", openSearch);
  searchBackdrop?.addEventListener("click", closeSearch);

  searchInput?.addEventListener("input", () => {
    void loadSearchIndex().then(() => renderResults(searchInput.value));
  });

  searchInput?.addEventListener("keydown", (e) => {
    const options = searchResults?.querySelectorAll<HTMLAnchorElement>("a[role='option']");
    if (!options || options.length === 0) return;
    if (e.key === "ArrowDown") {
      e.preventDefault();
      setActiveResult((activeResult + 1) % options.length);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setActiveResult((activeResult - 1 + options.length) % options.length);
    } else if (e.key === "Enter") {
      e.preventDefault();
      const target = options[activeResult >= 0 ? activeResult : 0];
      if (target) target.click();
    }
  });

  // Close on Escape; open on Ctrl/Cmd+K or "/" outside form fields
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeMenu();
      closeSearch();
      return;
    }
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      searchDialog?.classList.contains("hidden") ? openSearch() : closeSearch();
      return;
    }
    if (e.key === "/" && !e.ctrlKey && !e.metaKey && !e.altKey) {
      const target = e.target as HTMLElement | null;
      const tag = target?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || target?.isContentEditable) {
        return;
      }
      e.preventDefault();
      openSearch();
    }
  });
</script>
