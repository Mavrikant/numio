---
import { t, buildPath, type Locale } from "@/lib/i18n";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import CategoryNav from "./CategoryNav.astro";

export interface Props {
  locale: Locale;
  activeCategory?: string | undefined;
}

const { locale, activeCategory } = Astro.props;
const homeHref = buildPath(locale);
const siteName = t(locale, "site.name");
---

<header
  id="site-header"
  class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/95 backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/95 print:hidden"
>
  <div class="container-page">
    {/* Main header row */}
    <div class="flex h-14 items-center justify-between gap-4">
      {/* Logo + site name */}
      <a
        href={homeHref}
        class="flex shrink-0 items-center gap-2 font-semibold text-slate-900 dark:text-slate-100 hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded"
        aria-label={siteName}
      >
        {/* Brand mark — kept in sync with public/favicon.svg */}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-7 w-7"
          viewBox="0 0 32 32"
          aria-hidden="true"
        >
          <rect x="3" y="2" width="26" height="28" rx="4" fill="#0ea5e9" />
          <rect x="6" y="5" width="20" height="6" rx="1.5" fill="#082f49" />
          <rect x="22" y="6.5" width="3" height="3" rx="0.5" fill="#38bdf8" />
          <g fill="#ffffff">
            <circle cx="9" cy="16" r="1.5" />
            <circle cx="14" cy="16" r="1.5" />
            <circle cx="19" cy="16" r="1.5" />
            <circle cx="9" cy="21" r="1.5" />
            <circle cx="14" cy="21" r="1.5" />
            <circle cx="9" cy="26" r="1.5" />
            <circle cx="14" cy="26" r="1.5" />
          </g>
          <rect x="17" y="19.5" width="6" height="7.5" rx="1.5" fill="#f97316" />
          <text
            x="20"
            y="25"
            text-anchor="middle"
            font-family="ui-sans-serif, system-ui, sans-serif"
            font-size="5"
            font-weight="700"
            fill="#ffffff">=</text
          >
        </svg>
        <span class="text-base">{siteName}</span>
      </a>

      {/* Desktop nav — hidden on mobile */}
      <nav
        aria-label={t(locale, "nav.mainNavigation")}
        class="hidden md:flex md:items-center md:gap-1"
      >
        <a
          href={homeHref}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors"
        >
          {t(locale, "nav.home")}
        </a>
        <a
          href={`${buildPath(locale)}tools/`}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors"
        >
          {t(locale, "nav.tools")}
        </a>
      </nav>

      {/* Right controls */}
      <div class="flex items-center gap-1">
        {/* Search icon (placeholder) */}
        <button
          type="button"
          aria-label={t(locale, "nav.search")}
          class="hidden sm:inline-flex h-10 w-10 sm:h-9 sm:w-9 items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          disabled
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
        </button>

        <ThemeToggle locale={locale} />
        <LanguageSwitcher locale={locale} class="hidden sm:block" />

        {/* Mobile hamburger */}
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label={t(locale, "nav.openMenu")}
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="inline-flex h-10 w-10 sm:h-9 sm:w-9 items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 md:hidden"
        >
          <svg
            id="hamburger-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
          <svg
            id="close-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>

    {/* Category nav bar — always visible below main row */}
    <div class="border-t border-slate-100 py-2 dark:border-slate-800">
      <CategoryNav locale={locale} activeCategory={activeCategory} />
    </div>
  </div>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 md:hidden"
    aria-label={t(locale, "nav.mainNavigation")}
  >
    <div class="container-page py-4 space-y-4">
      <nav class="flex flex-col gap-1">
        <a
          href={homeHref}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-colors"
        >
          {t(locale, "nav.home")}
        </a>
        <a
          href={`${buildPath(locale)}tools/`}
          class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-colors"
        >
          {t(locale, "nav.tools")}
        </a>
      </nav>

      <div class="border-t border-slate-100 pt-4 dark:border-slate-800">
        <LanguageSwitcher locale={locale} class="w-full" />
      </div>
    </div>
  </div>
</header>

<script>
  // Header: sticky shadow on scroll + mobile menu toggle
  const header = document.getElementById("site-header");
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  // Sticky shadow
  if (header) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry && !entry.isIntersecting) {
          header.classList.add("shadow-sm");
        } else {
          header.classList.remove("shadow-sm");
        }
      },
      { threshold: 0, rootMargin: "-1px 0px 0px 0px" },
    );
    // Sentinel element trick: observe a zero-height element at the top of the page
    const sentinel = document.createElement("div");
    sentinel.style.height = "1px";
    sentinel.style.position = "absolute";
    sentinel.style.top = "0";
    sentinel.style.pointerEvents = "none";
    document.body.prepend(sentinel);
    observer.observe(sentinel);
  }

  // Mobile menu toggle
  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    menuBtn?.setAttribute("aria-expanded", "true");
    menuBtn?.setAttribute("aria-label", menuBtn.dataset.closeLabel ?? "Close menu");
    hamburgerIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    menuBtn?.setAttribute("aria-expanded", "false");
    menuBtn?.setAttribute("aria-label", menuBtn.dataset.openLabel ?? "Open menu");
    hamburgerIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  menuBtn?.addEventListener("click", () => {
    const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  // Close mobile menu on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  // Close mobile menu on resize to desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) closeMenu();
  });
</script>
