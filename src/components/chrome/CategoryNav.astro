---
import { getAvailableCategories } from "@/lib/registry";
import { t, buildPath, getCategoryLabel, type Locale } from "@/lib/i18n";

export interface Props {
  locale: Locale;
  /** Currently active category slug, if any */
  activeCategory?: string | undefined;
  class?: string;
}

const { locale, activeCategory, class: className } = Astro.props;
const categories = getAvailableCategories();
---

<nav
  aria-label={t(locale, "nav.categories")}
  class:list={["category-nav relative", className]}
>
  {/* Mobile: horizontal scroll pill bar */}
  <ul
    class="flex gap-2 overflow-x-auto pb-1 scrollbar-none sm:flex-wrap sm:overflow-visible sm:pb-0"
    role="list"
  >
    {
      categories.map((cat) => {
        const isActive = cat === activeCategory;
        const href = buildPath(locale, cat);
        const label = getCategoryLabel(locale, cat);
        return (
          <li class="shrink-0">
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "inline-flex items-center rounded-full px-4 py-2 sm:py-1.5 min-h-[40px] sm:min-h-0 text-sm font-medium",
                "transition-colors whitespace-nowrap",
                "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500",
                isActive
                  ? [
                      "bg-brand-600 text-white dark:bg-brand-500",
                    ]
                  : [
                      "bg-slate-100 text-slate-700 hover:bg-slate-200",
                      "dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700",
                    ],
              ]}
            >
              {label}
            </a>
          </li>
        );
      })
    }
    <li class="shrink-0">
      <a
        href={buildPath(locale, "sitemap")}
        class:list={[
          "inline-flex items-center gap-1.5 rounded-full px-4 py-2 sm:py-1.5 min-h-[40px] sm:min-h-0 text-sm font-medium",
          "transition-colors whitespace-nowrap",
          "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500",
          "border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-900",
          "dark:border-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-100",
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="7" height="7" rx="1" />
          <rect x="14" y="3" width="7" height="7" rx="1" />
          <rect x="3" y="14" width="7" height="7" rx="1" />
          <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        {t(locale, "nav.allCategories")}
      </a>
    </li>
  </ul>
  {/* Right-edge gradient fade hints horizontal scroll on mobile */}
  <div
    class="pointer-events-none absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-slate-50 dark:from-slate-900 to-transparent md:hidden"
    aria-hidden="true"
  />
</nav>
